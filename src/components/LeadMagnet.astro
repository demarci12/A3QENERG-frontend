---
// LeadMagnet.astro — Free Strategic Energy Audit Guide
---

<section
  id="lead-magnet"
  style="background:#18191A; padding:5rem 1.5rem;"
  aria-label="Download the free Strategic Energy Audit Guide"
>
  <div style="max-width:1160px; margin:0 auto; display:grid; grid-template-columns:1fr 1fr; gap:5rem; align-items:center;">

    <!-- Left: copy -->
    <div>
      <p style="font-size:0.6875rem; font-weight:600; text-transform:uppercase; letter-spacing:0.16em; color:#2A5C34; margin:0 0 1rem;">Free Resource</p>
      <h2 style="font-family:'Newsreader',Georgia,serif; font-size:clamp(1.75rem,3.5vw,2.5rem); font-weight:600; color:#FAFAF7; line-height:1.2; margin:0 0 1.25rem; letter-spacing:-0.01em;">
        Strategic Energy Audit Guide
      </h2>
      <p style="font-size:1rem; color:#9B9D9B; line-height:1.8; margin:0 0 2rem; max-width:480px;">
        A practitioner's framework for assessing your organisation's energy transformation readiness —
        distilled from four decades of executive leadership across European utilities.
      </p>
      <ul style="list-style:none; padding:0; margin:0 0 2.5rem; display:flex; flex-direction:column; gap:0.75rem;">
        {[
          'Transformation readiness diagnostic',
          'Gap analysis methodology',
          'Prioritisation framework for energy leaders',
        ].map(item => (
          <li style="display:flex; gap:0.75rem; font-size:0.9375rem; color:#9B9D9B; align-items:flex-start;">
            <span style="color:#2A5C34; font-weight:700; flex-shrink:0; margin-top:0.1em;">→</span>
            <span>{item}</span>
          </li>
        ))}
      </ul>
    </div>

    <!-- Right: form -->
    <div style="background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.08); border-radius:4px; padding:2.5rem;">
      <p style="font-family:'Newsreader',Georgia,serif; font-style:italic; font-size:1.0625rem; color:#E4E5E2; line-height:1.65; margin:0 0 2rem; border-left:2px solid #2A5C34; padding-left:1rem;">
        "Free, because the knowledge belongs to the sector — not behind a paywall."
      </p>

      <form
        id="lead-magnet-form"
        style="display:flex; flex-direction:column; gap:1rem;"
        novalidate
      >
        <div>
          <label for="lm-name" class="sr-only">Your name</label>
          <input
            id="lm-name"
            type="text"
            name="name"
            placeholder="Your name"
            autocomplete="name"
            style="width:100%; padding:0.75rem 1rem; font-size:0.9375rem; border:1px solid rgba(255,255,255,0.1); border-radius:3px; background:rgba(255,255,255,0.06); color:#FAFAF7; outline:none; font-family:inherit; transition:border-color 0.15s;"
            onfocus="this.style.borderColor='rgba(42,92,52,0.8)'"
            onblur="this.style.borderColor='rgba(255,255,255,0.1)'"
          />
        </div>
        <div>
          <label for="lm-email" class="sr-only">Your business email</label>
          <input
            id="lm-email"
            type="email"
            name="email"
            placeholder="Business email"
            required
            autocomplete="email"
            style="width:100%; padding:0.75rem 1rem; font-size:0.9375rem; border:1px solid rgba(255,255,255,0.1); border-radius:3px; background:rgba(255,255,255,0.06); color:#FAFAF7; outline:none; font-family:inherit; transition:border-color 0.15s;"
            onfocus="this.style.borderColor='rgba(42,92,52,0.8)'"
            onblur="this.style.borderColor='rgba(255,255,255,0.1)'"
          />
        </div>
        <button
          type="submit"
          style="width:100%; padding:0.875rem 1.5rem; font-size:0.9375rem; font-weight:600; color:#FAFAF7; background:#2A5C34; border:none; border-radius:3px; cursor:pointer; transition:background-color 0.2s; font-family:inherit; letter-spacing:0.01em;"
          onmouseover="this.style.backgroundColor='#3D7048'"
          onmouseout="this.style.backgroundColor='#2A5C34'"
        >
          Send Me the Guide →
        </button>
      </form>

      <p id="lm-success" style="display:none; margin-top:1.25rem; color:#2A5C34; font-size:0.875rem; font-weight:500; padding:0.875rem 1rem; background:rgba(42,92,52,0.12); border-radius:3px; border:1px solid rgba(42,92,52,0.3);">
        ✓ Check your inbox — the guide is on its way.
      </p>
      <p style="margin-top:1rem; font-size:0.75rem; color:#5A5D5A; text-align:center;">
        No spam. Unsubscribe at any time.
      </p>
    </div>

  </div>
</section>

<script>
  const form    = document.getElementById('lead-magnet-form') as HTMLFormElement | null;
  const success = document.getElementById('lm-success');

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const email = (form!.elements.namedItem('email') as HTMLInputElement)?.value?.trim();
    if (!email) return;

    // Replace with your email service endpoint (Mailchimp, ConvertKit, etc.)
    console.log('[LeadMagnet] Captured:', email);

    (form as HTMLFormElement).style.display = 'none';
    if (success) success.style.display = 'block';
  });
</script>

<style>
  @media (max-width: 860px) {
    section > div[style*="grid-template-columns:1fr 1fr"] {
      grid-template-columns: 1fr !important;
      gap: 3rem !important;
    }
  }
</style>
