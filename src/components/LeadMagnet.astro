---
import type { UITranslations } from '../i18n/utils';

interface Props {
  t: UITranslations;
  lang?: string;
}

const { t, lang = 'en' } = Astro.props;
const lm = t.leadMagnet;
const lmId = `lm-${Math.random().toString(36).slice(2, 7)}`;
---

<section id="lead-magnet" style="background:#18191A; padding:5rem 1.5rem;" aria-label={lm.headline}>
  <div style="max-width:1160px; margin:0 auto; display:grid; grid-template-columns:1fr 1fr; gap:5rem; align-items:center;">

    <div>
      <p style="font-size:0.6875rem; font-weight:600; text-transform:uppercase; letter-spacing:0.16em; color:#2A5C34; margin:0 0 1rem;">{lm.eyebrow}</p>
      <h2 style="font-family:'Newsreader',Georgia,serif; font-size:clamp(1.75rem,3.5vw,2.5rem); font-weight:600; color:#FAFAF7; line-height:1.2; margin:0 0 1.25rem; letter-spacing:-0.01em;">
        {lm.headline}
      </h2>
      <p style="font-size:1rem; color:#9B9D9B; line-height:1.8; margin:0 0 2rem; max-width:480px;">{lm.sub}</p>
      <ul style="list-style:none; padding:0; margin:0 0 2.5rem; display:flex; flex-direction:column; gap:0.75rem;">
        {lm.bullets.map(item => (
          <li style="display:flex; gap:0.75rem; font-size:0.9375rem; color:#9B9D9B; align-items:flex-start;">
            <span style="color:#2A5C34; font-weight:700; flex-shrink:0; margin-top:0.1em;">→</span>
            <span>{item}</span>
          </li>
        ))}
      </ul>
    </div>

    <div style="background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.08); border-radius:4px; padding:2.5rem;">
      <p style="font-family:'Newsreader',Georgia,serif; font-style:italic; font-size:1.0625rem; color:#E4E5E2; line-height:1.65; margin:0 0 2rem; border-left:2px solid #2A5C34; padding-left:1rem;">
        {lm.quote}
      </p>

      <form id={lmId} style="display:flex; flex-direction:column; gap:1rem;" novalidate>
        <div>
          <label for={`${lmId}-name`} class="sr-only">{lm.namePlaceholder}</label>
          <input id={`${lmId}-name`} type="text" name="name" placeholder={lm.namePlaceholder} autocomplete="name"
            style="width:100%; padding:0.75rem 1rem; font-size:0.9375rem; border:1px solid rgba(255,255,255,0.1); border-radius:3px; background:rgba(255,255,255,0.06); color:#FAFAF7; outline:none; font-family:inherit; transition:border-color 0.15s;"
            onfocus="this.style.borderColor='rgba(42,92,52,0.8)'" onblur="this.style.borderColor='rgba(255,255,255,0.1)'" />
        </div>
        <div>
          <label for={`${lmId}-email`} class="sr-only">{lm.emailPlaceholder}</label>
          <input id={`${lmId}-email`} type="email" name="email" placeholder={lm.emailPlaceholder} required autocomplete="email"
            style="width:100%; padding:0.75rem 1rem; font-size:0.9375rem; border:1px solid rgba(255,255,255,0.1); border-radius:3px; background:rgba(255,255,255,0.06); color:#FAFAF7; outline:none; font-family:inherit; transition:border-color 0.15s;"
            onfocus="this.style.borderColor='rgba(42,92,52,0.8)'" onblur="this.style.borderColor='rgba(255,255,255,0.1)'" />
        </div>
        <button type="submit"
          style="width:100%; padding:0.875rem 1.5rem; font-size:0.9375rem; font-weight:600; color:#FAFAF7; background:#2A5C34; border:none; border-radius:3px; cursor:pointer; transition:background-color 0.2s; font-family:inherit; letter-spacing:0.01em;"
          onmouseover="this.style.backgroundColor='#3D7048'" onmouseout="this.style.backgroundColor='#2A5C34'">
          {lm.submit}
        </button>
      </form>

      <p id={`${lmId}-success`} style="display:none; margin-top:1.25rem; color:#2A5C34; font-size:0.875rem; font-weight:500; padding:0.875rem 1rem; background:rgba(42,92,52,0.12); border-radius:3px; border:1px solid rgba(42,92,52,0.3);">
        {lm.success}
      </p>
      <p style="margin-top:1rem; font-size:0.75rem; color:#5A5D5A; text-align:center;">{lm.privacy}</p>
    </div>

  </div>
</section>

<script is:inline define:vars={{ formId: lmId }}>
  const form    = document.getElementById(formId);
  const success = document.getElementById(`${formId}-success`);
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const email = form.elements.namedItem('email')?.value?.trim();
    if (!email) return;
    console.log('[LeadMagnet] Captured:', email);
    form.style.display = 'none';
    if (success) success.style.display = 'block';
  });
</script>

<style>
  @media (max-width: 860px) {
    section > div[style*="grid-template-columns:1fr 1fr"] {
      grid-template-columns: 1fr !important;
      gap: 3rem !important;
    }
  }
</style>
