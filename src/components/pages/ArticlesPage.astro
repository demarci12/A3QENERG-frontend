---
import Layout from '../../layouts/Layout.astro';
import { formatDate, getCategories, getPosts, stripHtml } from '../../utils/wordpress';
import type { Lang, UITranslations } from '../../i18n/utils';

interface Props { t: UITranslations; lang: Lang; }
const { t, lang } = Astro.props;

const localHref = (path: string) => lang === 'en' ? path : `/${lang}${path}`;
const ar = t.articles;

const posts = await getPosts(100);
const [featured, ...rest] = posts;
---

<Layout title={`Articles — Ferenc Csulak`}
  description="Strategic insights on energy transformation, leadership, ESG, and organisational performance by Ferenc Csulak."
  lang={lang} t={t}>

  <!-- HERO -->
  <section style="padding:6rem 1.5rem 5rem; max-width:1160px; margin:0 auto;">
    <div style="max-width:680px;">
      <p class="eyebrow" style="margin:0 0 1.25rem;">{ar.eyebrow}</p>
      <h1 style="font-family:'Newsreader',Georgia,serif; font-size:clamp(2.25rem,5vw,3.25rem); font-weight:600; color:#18191A; line-height:1.18; margin:0 0 1.5rem; letter-spacing:-0.01em;">{ar.headline}</h1>
      <p style="font-size:1.0625rem; color:#5A5D5A; line-height:1.75; margin:0;">{ar.countLabel(posts.length)}</p>
    </div>
  </section>

  <hr class="divider" style="max-width:1160px; margin:0 auto;" />

  <!-- FEATURED POST -->
  {featured && (
    <section style="padding:4rem 1.5rem; max-width:1160px; margin:0 auto;">
      <p class="eyebrow" style="margin:0 0 1.5rem;">{ar.featured}</p>
      <a href={localHref(`/articles/${featured.slug}`)}
        style="display:grid; grid-template-columns:1fr 1fr; gap:0; text-decoration:none; color:inherit; border:1px solid #E4E5E2; border-radius:4px; overflow:hidden; transition:border-color 0.2s;"
        onmouseover="this.style.borderColor='#2A5C34'" onmouseout="this.style.borderColor='#E4E5E2'">
        <div style="padding:3rem; background:#F3F4F1; display:flex; flex-direction:column; justify-content:space-between; min-height:280px;">
          <div>
            {getCategories(featured)[0] && (
              <p style="font-size:0.625rem; font-weight:600; text-transform:uppercase; letter-spacing:0.16em; color:#2A5C34; margin:0 0 1.25rem;">{getCategories(featured)[0]}</p>
            )}
            <h2 style="font-family:'Newsreader',Georgia,serif; font-size:clamp(1.375rem,2.5vw,1.875rem); font-weight:600; color:#18191A; line-height:1.25; margin:0;">
              {featured.title.rendered}
            </h2>
          </div>
          <div style="margin-top:2rem;">
            <time datetime={featured.date} style="font-size:0.75rem; color:#9B9D9B; text-transform:uppercase; letter-spacing:0.1em; font-weight:500;">
              {formatDate(featured.date, 'en-GB')}
            </time>
          </div>
        </div>
        <div style="padding:3rem; background:#FAFAF7; display:flex; flex-direction:column; justify-content:space-between;">
          <p style="font-size:1rem; color:#5A5D5A; line-height:1.8; margin:0;">{stripHtml(featured.excerpt.rendered).slice(0, 280)}…</p>
          <p style="font-size:0.875rem; font-weight:600; color:#2A5C34; margin:2rem 0 0;">{ar.readArticle}</p>
        </div>
      </a>
    </section>
  )}

  <!-- ARTICLES LIST -->
  <section style="padding:0 1.5rem 6rem; max-width:1160px; margin:0 auto;">
    {rest.length > 0 && (
      <>
        <p class="eyebrow" style="margin:0 0 2rem;">{ar.allArticles}</p>
        <div style="display:flex; flex-direction:column; border:1px solid #E4E5E2; border-radius:4px; overflow:hidden;">
          {rest.map((post) => (
            <article style="border-bottom:1px solid #E4E5E2;">
              <a href={localHref(`/articles/${post.slug}`)}
                style="display:grid; grid-template-columns:140px 1fr; gap:0; text-decoration:none; color:inherit; transition:background-color 0.15s;"
                onmouseover="this.style.backgroundColor='#F3F4F1'" onmouseout="this.style.backgroundColor='transparent'">
                <div style="padding:1.75rem 1.5rem; border-right:1px solid #E4E5E2; display:flex; align-items:flex-start; background:#F3F4F1;">
                  <time datetime={post.date} style="font-size:0.75rem; color:#9B9D9B; line-height:1.5; font-weight:500;">
                    {formatDate(post.date, 'en-GB')}
                  </time>
                </div>
                <div style="padding:1.75rem 2rem;">
                  {getCategories(post)[0] && (
                    <p style="font-size:0.625rem; font-weight:600; text-transform:uppercase; letter-spacing:0.14em; color:#2A5C34; margin:0 0 0.625rem;">{getCategories(post)[0]}</p>
                  )}
                  <h2 style="font-family:'Newsreader',Georgia,serif; font-size:1.1875rem; font-weight:600; color:#18191A; margin:0 0 0.6rem; line-height:1.3;">{post.title.rendered}</h2>
                  <p style="font-size:0.875rem; color:#5A5D5A; line-height:1.7; margin:0; max-width:600px;">{stripHtml(post.excerpt.rendered).slice(0, 180)}…</p>
                </div>
              </a>
            </article>
          ))}
        </div>
      </>
    )}
    {posts.length === 0 && (
      <p style="color:#9B9D9B; font-size:1rem; padding:3rem 0;">{ar.empty}</p>
    )}
  </section>

  <!-- NEWSLETTER CTA -->
  <section style="border-top:1px solid #E4E5E2; background:#F3F4F1; padding:5rem 1.5rem;">
    <div style="max-width:560px; margin:0 auto; text-align:center;">
      <p class="eyebrow" style="margin:0 0 1rem;">{ar.newsletter.eyebrow}</p>
      <h2 style="font-family:'Newsreader',Georgia,serif; font-size:clamp(1.5rem,2.5vw,2rem); font-weight:600; color:#18191A; line-height:1.25; margin:0 0 1rem;">{ar.newsletter.headline}</h2>
      <p style="font-size:0.9375rem; color:#5A5D5A; line-height:1.75; margin:0 0 2rem;">{ar.newsletter.sub}</p>
      <a href={localHref('/#lead-magnet')} class="btn-primary" style="font-size:0.9375rem;">{ar.newsletter.btn}</a>
    </div>
  </section>

</Layout>

<style>
  @media (max-width: 680px) {
    a[style*="grid-template-columns:1fr 1fr"] { grid-template-columns: 1fr !important; }
    a[style*="grid-template-columns:140px 1fr"] { grid-template-columns: 1fr !important; }
  }
</style>
