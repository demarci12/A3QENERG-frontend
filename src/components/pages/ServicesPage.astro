---
import Layout from '../../layouts/Layout.astro';
import type { Lang, UITranslations } from '../../i18n/utils';

interface Props { t: UITranslations; lang: Lang; }
const { t, lang } = Astro.props;

const localHref = (path: string) => lang === 'en' ? path : `/${lang}${path}`;
const s = t.services;
---

<Layout title={`Work With Me — Ferenc Csulak`}
  description={s.sub}
  lang={lang} t={t}>

  <!-- HERO -->
  <section style="padding:6rem 1.5rem 5rem; max-width:1160px; margin:0 auto;">
    <div style="display:grid; grid-template-columns:1fr 1fr; gap:5rem; align-items:end;">
      <div>
        <p class="eyebrow" style="margin:0 0 1.5rem;">{s.eyebrow}</p>
        <h1 style="font-family:'Newsreader',Georgia,serif; font-size:clamp(2.25rem,5vw,3.25rem); font-weight:600; color:#18191A; line-height:1.18; margin:0; letter-spacing:-0.01em;">
          {s.headline}<br />
          <em style="color:#2A5C34; font-style:italic;">{s.headlineEm}</em>
        </h1>
      </div>
      <div style="padding-bottom:0.5rem;">
        <p style="font-size:1.0625rem; color:#5A5D5A; line-height:1.8; margin:0 0 1.5rem;">{s.sub}</p>
        <a href={localHref('/contact')} class="btn-primary" style="font-size:0.9375rem;">{s.cta}</a>
      </div>
    </div>
  </section>

  <hr class="divider" style="max-width:1160px; margin:0 auto;" />

  <!-- SERVICES LIST -->
  <section style="padding:5rem 1.5rem; max-width:1160px; margin:0 auto;">
    <div style="display:flex; flex-direction:column; gap:1px; background:#E4E5E2; border:1px solid #E4E5E2; border-radius:4px; overflow:hidden;">
      {s.items.map((item) => (
        <article id={item.id} style="display:grid; grid-template-columns:1fr 2fr; gap:0; background:#FAFAF7;">
          <div style="padding:2.5rem; background:#F3F4F1; border-right:1px solid #E4E5E2; display:flex; flex-direction:column; justify-content:space-between;">
            <div>
              <p class="eyebrow" style="margin:0 0 0.875rem;">{item.eyebrow}</p>
              <h2 style="font-family:'Newsreader',Georgia,serif; font-size:1.375rem; font-weight:600; color:#18191A; margin:0; line-height:1.3;">{item.title}</h2>
            </div>
            <div style="margin-top:2rem;">
              <p style="font-size:0.6875rem; font-weight:500; text-transform:uppercase; letter-spacing:0.12em; color:#9B9D9B; margin:0 0 0.35rem;">{s.durationLabel}</p>
              <p style="font-size:0.9375rem; font-weight:500; color:#5A5D5A; margin:0;">{item.duration}</p>
            </div>
          </div>
          <div style="padding:2.5rem; display:flex; flex-direction:column; gap:1.5rem;">
            <p style="font-size:1rem; color:#2A2B2A; line-height:1.8; margin:0;">{item.summary}</p>
            <ul style="list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:0.6rem;">
              {item.details.map(d => (
                <li style="display:flex; gap:0.75rem; font-size:0.875rem; color:#5A5D5A; line-height:1.65; align-items:flex-start;">
                  <span style="color:#2A5C34; font-weight:700; flex-shrink:0; margin-top:0.05em;">→</span>
                  <span>{d}</span>
                </li>
              ))}
            </ul>
            <div style="padding-top:0.5rem;">
              <a href={localHref('/contact')}
                style="display:inline-flex; align-items:center; gap:0.4rem; font-size:0.875rem; font-weight:600; color:#2A5C34; text-decoration:none; transition:color 0.15s;"
                onmouseover="this.style.color='#1A3D22'" onmouseout="this.style.color='#2A5C34'">
                {s.enquire}
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- DISCOVERY CALL -->
  <section style="background:#F3F4F1; padding:5rem 1.5rem; border-top:1px solid #E4E5E2;">
    <div style="max-width:1160px; margin:0 auto; display:grid; grid-template-columns:1fr 1fr; gap:5rem; align-items:center;">
      <div>
        <p class="eyebrow" style="margin:0 0 1rem;">{s.discovery.eyebrow}</p>
        <h2 style="font-family:'Newsreader',Georgia,serif; font-size:clamp(1.75rem,3vw,2.25rem); font-weight:600; color:#18191A; line-height:1.25; margin:0 0 1.25rem;">
          {s.discovery.headline}
        </h2>
        <p style="font-size:1rem; color:#5A5D5A; line-height:1.8; margin:0 0 2rem;">{s.discovery.body}</p>
        <div style="display:flex; gap:0.875rem; flex-wrap:wrap;">
          <a href={localHref('/contact')} class="btn-primary" style="font-size:0.9375rem;">{s.discovery.btn1}</a>
          <a href={localHref('/about-us')} class="btn-outline" style="font-size:0.9375rem;">{s.discovery.btn2}</a>
        </div>
      </div>
      <div style="display:flex; flex-direction:column; gap:1.25rem;">
        {s.discovery.steps.map(([title, body], i) => (
          <div style="display:flex; gap:1.25rem; align-items:flex-start;">
            <span style="font-family:'Newsreader',Georgia,serif; font-size:1.5rem; font-weight:600; color:#C8CAC5; flex-shrink:0; line-height:1; margin-top:0.1rem;">
              {String(i + 1).padStart(2, '0')}
            </span>
            <div>
              <p style="font-weight:600; color:#18191A; margin:0 0 0.25rem; font-size:0.9375rem;">{title}</p>
              <p style="font-size:0.875rem; color:#5A5D5A; margin:0; line-height:1.65;">{body}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- BOTTOM CTA -->
  <section style="background:#18191A; padding:5rem 1.5rem; text-align:center;">
    <div style="max-width:560px; margin:0 auto;">
      <p class="eyebrow" style="color:#2A5C34; margin:0 0 1.25rem;">{s.cta2.eyebrow}</p>
      <h2 style="font-family:'Newsreader',Georgia,serif; font-size:clamp(1.6rem,3vw,2.25rem); font-weight:600; color:#FAFAF7; line-height:1.25; margin:0 0 2rem;">{s.cta2.headline}</h2>
      <a href={localHref('/contact')}
        style="padding:0.9rem 2.25rem; background:#2A5C34; color:#FAFAF7; font-size:1rem; font-weight:600; text-decoration:none; border-radius:3px; display:inline-block; transition:background-color 0.2s;"
        onmouseover="this.style.backgroundColor='#3D7048'" onmouseout="this.style.backgroundColor='#2A5C34'">
        {s.cta2.btn}
      </a>
    </div>
  </section>

</Layout>

<style>
  @media (max-width: 860px) {
    article[style*="grid-template-columns:1fr 2fr"] { grid-template-columns: 1fr !important; }
    div[style*="grid-template-columns:1fr 1fr"] { grid-template-columns: 1fr !important; gap: 2.5rem !important; }
  }
</style>
