---
interface Props {
  currentLabel?: string;
}
const { currentLabel = 'Current' } = Astro.props;

const entries = [
  { period: 'Apr 2022 – Present', role: 'General Manager',           company: 'Delgaz Grid',                             current: true  },
  { period: '2017 – 2022',        role: 'CEO',                        company: 'Delgaz Grid',                             current: false },
  { period: '2015 – 2017',        role: 'CEO',                        company: 'E.ON Hungária Zrt.',                      current: false },
  { period: '2015 – 2017',        role: 'CEO',                        company: 'E.ON Közép-dunántúli Gázhálózati ZRT',   current: false },
  { period: '2004 – 2008',        role: 'Deputy General Director',    company: 'E.ON Moldova',                            current: false },
  { period: '2001 – 2004',        role: 'Department Leader',          company: 'ÉDÁSZ RT',                                current: false },
];
---

<div style="position:relative; padding-left:2rem;">
  <div style="position:absolute; left:0.5rem; top:0; bottom:0; width:2px; background:linear-gradient(to bottom,#2A5C34,#E4E5E2);" aria-hidden="true"></div>

  {entries.map((entry, i) => (
    <div style={`position:relative; padding-bottom:${i < entries.length - 1 ? '2.5rem' : '0'}; padding-left:1.5rem;`}>
      <div
        style={`position:absolute; left:-0.35rem; top:0.3rem; width:0.9rem; height:0.9rem; border-radius:50%; background-color:${entry.current ? '#2A5C34' : '#FAFAF7'}; border:2px solid ${entry.current ? '#2A5C34' : '#C8CAC5'}; flex-shrink:0;`}
        aria-hidden="true"
      ></div>
      <div>
        <p style="font-size:0.75rem; text-transform:uppercase; letter-spacing:0.1em; color:#2A5C34; margin:0 0 0.2rem; font-weight:600;">
          {entry.period}
          {entry.current && (
            <span style="margin-left:0.5rem; background:#2A5C34; color:#FAFAF7; font-size:0.65rem; padding:0.1rem 0.4rem; border-radius:3px; vertical-align:middle; letter-spacing:0.05em;">
              {currentLabel}
            </span>
          )}
        </p>
        <p style="font-family:'Newsreader',Georgia,serif; font-size:1.1rem; font-weight:700; color:#18191A; margin:0 0 0.1rem; line-height:1.3;">{entry.role}</p>
        <p style="font-size:0.9rem; color:#5A5D5A; margin:0;">{entry.company}</p>
      </div>
    </div>
  ))}
</div>
