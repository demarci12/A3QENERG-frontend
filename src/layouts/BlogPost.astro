---
// Legacy BlogPost layout — wraps content collection posts
// New content lives under src/pages/articles/*
import Layout from './Layout.astro';

interface Props {
  title: string;
  description?: string;
  pubDate?: Date;
  updatedDate?: Date;
  heroImage?: { src: string };
}

const { title, description, pubDate, heroImage } = Astro.props;
---

<Layout title={title} description={description}>
  <article style="max-width:760px; margin:0 auto; padding:3rem 1.5rem 5rem;">

    {heroImage && (
      <img
        src={heroImage.src}
        alt=""
        style="width:100%; height:auto; border-radius:6px; margin-bottom:2rem; max-height:480px; object-fit:cover;"
      />
    )}

    <h1 style="font-family:'Newsreader',Georgia,serif; font-size:clamp(1.75rem,4vw,2.75rem); font-weight:700; color:#173b1e; line-height:1.2; margin:0 0 1rem;">
      {title}
    </h1>

    {pubDate && (
      <p style="font-size:0.8125rem; color:#c8cac8; margin:0 0 2rem;">
        <time datetime={pubDate.toISOString()}>
          {pubDate.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}
        </time>
      </p>
    )}

    <div class="prose" style="font-family:'Newsreader',Georgia,serif; font-size:1.0625rem; line-height:1.8; color:#3d3f3d;">
      <slot />
    </div>
  </article>
</Layout>
