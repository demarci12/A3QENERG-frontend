---
import Layout from '../layouts/Layout.astro';

const services = [
  {
    id: 'roadmap',
    eyebrow: 'Strategic Planning',
    title: 'Heading for a roadmap',
    summary: 'The roadmap program guides organisations through creating strategic direction based on vision and mission statements, clarifying goals and milestones for mid- and long-term planning.',
    details: [
      'Peer-to-peer interviews to assess current status and identify gaps',
      'Roadmap delivered across three scenarios for flexibility',
      'Clarity in goals and milestones on mid- and long-term',
    ],
    duration: '4 – 8 weeks',
  },
  {
    id: 'mentoring',
    eyebrow: 'Leadership Development',
    title: 'Mentoring',
    summary: 'The mentoring process is dedicated to beginners strengthening their career path and knowledge in specific fields and general management, and also to experienced middle and top managers who see opportunities in enhancing their skills and competences.',
    details: [
      'Tailored to both early-career professionals and experienced managers',
      'Meeting frequency and goals agreed mutually',
      'Typical duration: 6 weeks to 3 months',
    ],
    duration: '6 weeks – 3 months',
  },
  {
    id: 'leadership-on-top',
    eyebrow: 'Executive Team',
    title: 'Leadership on top',
    summary: 'A program targeting middle and top managers, offering a new set of management tools and techniques, in order to improve their performance and mood.',
    details: [
      'Assessment of current leadership styles',
      'Tailored approach developed for each participant',
      'Implementation support included',
    ],
    duration: '3 – 6 months',
  },
  {
    id: 'multigenerational',
    eyebrow: 'Workforce',
    title: 'Multiple generation management',
    summary: 'Our days the new media/technological generations are active in the workforce market. Therefore often in one company the management has to deal with 3–4 different generations characterised by significant cultural and behavioural differences. The program is giving a set of tools in understanding and managing these differences.',
    details: [
      'Tools for understanding generational cultural and behavioural differences',
      'Managing 3–4 simultaneous generations in one organisation',
      'Optional implementation support available',
    ],
    duration: '4 – 12 weeks',
  },
  {
    id: 'leaders-for-safety',
    eyebrow: 'Safety Culture',
    title: 'Leaders for safety',
    summary: 'The new global trends of urbanisation and the top attention for digital world lead to decreasing professional skills in professions with high skills needed in handling manual tools where robots or digital solutions cannot cover the needs. The number of severe accidents is increasing in these industries, challenging top and middle management.',
    details: [
      'HSE assessments across management and frontline levels',
      'Management tools for safety-focused organisations',
      'Supports operative, middle and top management',
    ],
    duration: '6 – 12 weeks',
  },
  {
    id: 'esg',
    eyebrow: 'Sustainability Strategy',
    title: 'Environmental & Social & Governance on focus',
    summary: 'Not only due to the legal requirements published by the European Union but also the needs of managing climate changes create a special focus for the sustainability of any kind of industry and business. The program result is an ESG strategy and is supporting to implement on different units of the company.',
    details: [
      'ESG strategy development aligned with EU legal requirements',
      'Measurement toolsets for tracking sustainability metrics',
      'Implementation support across organisational units',
    ],
    duration: '6 – 16 weeks',
  },
];
---

<Layout
  title="Our Services — A3QENERG"
  description="How can we help you? Roadmap, Mentoring, Leadership on top, Multiple generation management, Leaders for safety, ESG on focus."
>

  <!-- ═══════════════════════════════════════════════════════ PAGE HERO -->
  <section style="padding:5rem 1.5rem 4rem; max-width:1200px; margin:0 auto;">
    <div style="max-width:700px;">
      <p style="font-size:0.75rem; text-transform:uppercase; letter-spacing:0.14em; color:#2E5233; margin-bottom:1rem; font-weight:600;">
        What We Offer
      </p>
      <h1 style="font-family:'Newsreader',Georgia,serif; font-size:clamp(2rem,4.5vw,3rem); font-weight:700; color:#173b1e; line-height:1.2; margin-bottom:1.25rem;">
        Our Services
      </h1>
      <p style="font-family:'Newsreader',Georgia,serif; font-size:clamp(1.1rem,2.5vw,1.35rem); color:#3d3f3d; line-height:1.7;">
        How can we help you?
      </p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════ DIVIDER -->
  <div style="border-top:1px solid #e7e8e7; max-width:1200px; margin:0 auto;"></div>

  <!-- ═══════════════════════════════════════════════════════ SERVICES GRID -->
  <section style="padding:4rem 1.5rem; max-width:1200px; margin:0 auto;">
    <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(320px,1fr)); gap:2rem;">
      {services.map((s) => (
        <article
          id={s.id}
          style="padding:2rem; border:1px solid #e7e8e7; border-radius:6px; display:flex; flex-direction:column; gap:1rem;"
        >
          <!-- Eyebrow + duration -->
          <div style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:0.5rem;">
            <p style="font-size:0.7rem; text-transform:uppercase; letter-spacing:0.1em; color:#2E5233; font-weight:600; margin:0;">
              {s.eyebrow}
            </p>
            <span style="font-size:0.7rem; color:#c8cac8; background:#e7e8e7; padding:0.15rem 0.5rem; border-radius:3px;">
              {s.duration}
            </span>
          </div>

          <!-- Title -->
          <h2 style="font-family:'Newsreader',Georgia,serif; font-size:1.375rem; font-weight:700; color:#173b1e; margin:0; line-height:1.25;">
            {s.title}
          </h2>

          <!-- Summary -->
          <p style="font-size:0.9375rem; color:#3d3f3d; line-height:1.7; margin:0;">
            {s.summary}
          </p>

          <!-- Details -->
          <ul style="list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:0.5rem; flex:1;">
            {s.details.map((d) => (
              <li style="display:flex; gap:0.6rem; font-size:0.875rem; color:#3d3f3d; line-height:1.6;">
                <span style="color:#2E5233; flex-shrink:0; font-weight:700; margin-top:0.1rem;">—</span>
                <span>{d}</span>
              </li>
            ))}
          </ul>

          <!-- CTA -->
          <div style="margin-top:auto; padding-top:1rem; border-top:1px solid #e7e8e7;">
            <a
              href="/contact"
              style="display:inline-block; padding:0.55rem 1.1rem; font-size:0.875rem; font-weight:600; color:#f9f9f8; background-color:#2E5233; text-decoration:none; border-radius:4px; transition:background-color 0.2s;"
              onmouseover="this.style.backgroundColor='#173b1e'"
              onmouseout="this.style.backgroundColor='#2E5233'"
            >
              Enquire →
            </a>
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════ BOOKING SECTION -->
  <section style="background-color:#f0f2f0; padding:5rem 1.5rem;">
    <div style="max-width:1200px; margin:0 auto;">

      <div style="max-width:560px; margin-bottom:2.5rem;">
        <p style="font-size:0.75rem; text-transform:uppercase; letter-spacing:0.14em; color:#2E5233; margin-bottom:1rem; font-weight:600;">
          Direct Booking
        </p>
        <h2 style="font-family:'Newsreader',Georgia,serif; font-size:clamp(1.6rem,3vw,2rem); font-weight:700; color:#173b1e; line-height:1.25; margin-bottom:1rem;">
          Book a Discovery Call
        </h2>
        <p style="font-size:0.9375rem; color:#3d3f3d; line-height:1.75;">
          A 30-minute, no-obligation conversation to understand your situation and explore whether there is a fit. Select a time that works for you below.
        </p>
      </div>

      <!-- Calendly placeholder -->
      <div
        style="background:#f9f9f8; border:1px dashed #c8cac8; border-radius:6px; padding:3rem; text-align:center; min-height:200px; display:flex; flex-direction:column; align-items:center; justify-content:center; gap:0.75rem;"
        id="calendly-embed"
      >
        <p style="font-size:0.875rem; color:#c8cac8; margin:0;">Calendly / scheduler embed goes here</p>
        <p style="font-size:0.75rem; color:#c8cac8; margin:0;">
          Paste your Calendly inline widget script inside the <code style="background:#e7e8e7; padding:0.1rem 0.4rem; border-radius:3px; color:#3d3f3d;">#calendly-embed</code> div.
        </p>
        <a
          href="/contact"
          style="margin-top:0.5rem; padding:0.65rem 1.4rem; font-size:0.875rem; font-weight:600; color:#f9f9f8; background-color:#2E5233; text-decoration:none; border-radius:4px;"
        >
          Or use the contact form →
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════ BOTTOM CTA -->
  <section style="background:linear-gradient(135deg,#2E5233,#173b1e); padding:5rem 1.5rem; text-align:center;">
    <div style="max-width:600px; margin:0 auto;">
      <h2 style="font-family:'Newsreader',Georgia,serif; font-size:clamp(1.6rem,3.5vw,2.4rem); font-weight:700; color:#f9f9f8; line-height:1.25; margin-bottom:2rem;">
        Overcome your obstacles.<br />Get Business Coaching, Today!
      </h2>
      <a
        href="/contact"
        style="display:inline-block; padding:0.9rem 2.25rem; background-color:#f9f9f8; color:#173b1e; font-size:1rem; font-weight:700; text-decoration:none; border-radius:4px; transition:background-color 0.2s;"
        onmouseover="this.style.backgroundColor='#e7e8e7'"
        onmouseout="this.style.backgroundColor='#f9f9f8'"
      >
        Book Consultation
      </a>
    </div>
  </section>

</Layout>
