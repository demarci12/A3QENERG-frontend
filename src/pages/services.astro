---
import Layout from '../layouts/Layout.astro';

const services = [
  {
    id: 'roadmap',
    eyebrow: 'Strategic Planning',
    title: 'Heading for a Roadmap',
    summary: 'From vision and mission to a clear, multi-scenario strategic roadmap. I guide leadership teams through an honest assessment of where they are — and a rigorous process to define where they are going.',
    details: [
      'Peer-to-peer interviews to assess current status and identify gaps',
      'Roadmap delivered across three scenarios for strategic flexibility',
      'Clear goals and milestones for mid- and long-term horizons',
    ],
    duration: '4 – 8 weeks',
  },
  {
    id: 'mentoring',
    eyebrow: 'Individual Development',
    title: 'Executive Mentoring',
    summary: 'One-to-one mentoring for early-career professionals building their path, and for experienced managers who want to sharpen their edge. Direct, honest, and grounded in decades of field experience.',
    details: [
      'Tailored to your specific career stage and goals',
      'Frequency and structure agreed mutually at the outset',
      'Typical engagement: 6 weeks to 3 months',
    ],
    duration: '6 weeks – 3 months',
  },
  {
    id: 'leadership-on-top',
    eyebrow: 'Executive Team',
    title: 'Leadership on Top',
    summary: 'A programme for middle and senior managers seeking a new toolkit. Practical, field-tested management techniques to improve performance, decision quality, and team culture simultaneously.',
    details: [
      'Assessment of current leadership styles and gaps',
      'Customised approach developed for each participant',
      'Implementation support and follow-up included',
    ],
    duration: '3 – 6 months',
  },
  {
    id: 'multigenerational',
    eyebrow: 'Workforce & Culture',
    title: 'Multi-Generation Management',
    summary: 'Three or four generations working side by side — each with different expectations, communication styles, and motivations. I equip managers with the tools to understand and lead across this divide.',
    details: [
      'Tools for diagnosing generational dynamics in your organisation',
      'Practical frameworks for cross-generational collaboration',
      'Optional implementation support available',
    ],
    duration: '4 – 12 weeks',
  },
  {
    id: 'leaders-for-safety',
    eyebrow: 'Safety Culture',
    title: 'Leaders for Safety',
    summary: 'Severe accidents are rising in industries that depend on skilled manual work. I help operative, middle, and senior management build a genuine safety culture — not a compliance exercise.',
    details: [
      'HSE assessments across management and frontline levels',
      'Management tools for safety-focused leadership',
      'Supports operative, middle and top management layers',
    ],
    duration: '6 – 12 weeks',
  },
  {
    id: 'esg',
    eyebrow: 'Sustainability Strategy',
    title: 'ESG on Focus',
    summary: 'Beyond EU legal requirements — a real ESG strategy that creates organisational resilience and stakeholder trust. From gap analysis through to implementation across your business units.',
    details: [
      'ESG strategy development aligned with EU regulatory requirements',
      'Measurement toolsets for tracking sustainability metrics',
      'Implementation support across organisational units',
    ],
    duration: '6 – 16 weeks',
  },
];
---

<Layout
  title="Work With Me — Ferenc Csulak"
  description="Strategic advisory, executive mentoring, leadership development, multi-generation management, safety culture, and ESG strategy. Built on 40 years in European energy."
>

  <!-- ═══════════════════════════════════════════════════ HERO -->
  <section style="padding:6rem 1.5rem 5rem; max-width:1160px; margin:0 auto;">
    <div style="display:grid; grid-template-columns:1fr 1fr; gap:5rem; align-items:end;">

      <div>
        <p class="eyebrow" style="margin:0 0 1.5rem;">Work With Me</p>
        <h1 style="font-family:'Newsreader',Georgia,serif; font-size:clamp(2.25rem,5vw,3.25rem); font-weight:600; color:#18191A; line-height:1.18; margin:0; letter-spacing:-0.01em;">
          Expertise earned<br />
          <em style="color:#2A5C34; font-style:italic;">at the coalface.</em>
        </h1>
      </div>

      <div style="padding-bottom:0.5rem;">
        <p style="font-size:1.0625rem; color:#5A5D5A; line-height:1.8; margin:0 0 1.5rem;">
          Every programme I offer is built on lived experience — not theory. I have held the roles,
          navigated the politics, and been accountable for the results. That is what I bring to the table.
        </p>
        <a href="/contact" class="btn-primary" style="font-size:0.9375rem;">
          Book a Discovery Call
        </a>
      </div>

    </div>
  </section>

  <hr class="divider" style="max-width:1160px; margin:0 auto;" />

  <!-- ═══════════════════════════════════════════════════ SERVICES -->
  <section style="padding:5rem 1.5rem; max-width:1160px; margin:0 auto;">

    <div style="display:flex; flex-direction:column; gap:1px; background:#E4E5E2; border:1px solid #E4E5E2; border-radius:4px; overflow:hidden;">
      {services.map((s, i) => (
        <article
          id={s.id}
          style="display:grid; grid-template-columns:1fr 2fr; gap:0; background:#FAFAF7;"
        >
          <!-- Left panel -->
          <div style="padding:2.5rem; background:#F3F4F1; border-right:1px solid #E4E5E2; display:flex; flex-direction:column; justify-content:space-between;">
            <div>
              <p class="eyebrow" style="margin:0 0 0.875rem;">{s.eyebrow}</p>
              <h2 style="font-family:'Newsreader',Georgia,serif; font-size:1.375rem; font-weight:600; color:#18191A; margin:0; line-height:1.3;">
                {s.title}
              </h2>
            </div>
            <div style="margin-top:2rem;">
              <p style="font-size:0.6875rem; font-weight:500; text-transform:uppercase; letter-spacing:0.12em; color:#9B9D9B; margin:0 0 0.35rem;">Duration</p>
              <p style="font-size:0.9375rem; font-weight:500; color:#5A5D5A; margin:0;">{s.duration}</p>
            </div>
          </div>

          <!-- Right panel -->
          <div style="padding:2.5rem; display:flex; flex-direction:column; gap:1.5rem;">
            <p style="font-size:1rem; color:#2A2B2A; line-height:1.8; margin:0;">{s.summary}</p>

            <ul style="list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:0.6rem;">
              {s.details.map((d) => (
                <li style="display:flex; gap:0.75rem; font-size:0.875rem; color:#5A5D5A; line-height:1.65; align-items:flex-start;">
                  <span style="color:#2A5C34; font-weight:700; flex-shrink:0; margin-top:0.05em;">→</span>
                  <span>{d}</span>
                </li>
              ))}
            </ul>

            <div style="padding-top:0.5rem;">
              <a
                href="/contact"
                style="display:inline-flex; align-items:center; gap:0.4rem; font-size:0.875rem; font-weight:600; color:#2A5C34; text-decoration:none; transition:color 0.15s;"
                onmouseover="this.style.color='#1A3D22'"
                onmouseout="this.style.color='#2A5C34'"
              >
                Enquire about this programme →
              </a>
            </div>
          </div>

        </article>
      ))}
    </div>

  </section>

  <!-- ═══════════════════════════════════════════════════ DISCOVERY CALL -->
  <section style="background:#F3F4F1; padding:5rem 1.5rem; border-top:1px solid #E4E5E2;">
    <div style="max-width:1160px; margin:0 auto; display:grid; grid-template-columns:1fr 1fr; gap:5rem; align-items:center;">

      <div>
        <p class="eyebrow" style="margin:0 0 1rem;">Start Here</p>
        <h2 style="font-family:'Newsreader',Georgia,serif; font-size:clamp(1.75rem,3vw,2.25rem); font-weight:600; color:#18191A; line-height:1.25; margin:0 0 1.25rem;">
          Book a 30-minute discovery call.
        </h2>
        <p style="font-size:1rem; color:#5A5D5A; line-height:1.8; margin:0 0 2rem;">
          A no-obligation conversation to understand your situation and explore
          whether there is a fit. I will be direct about what I can and cannot offer.
        </p>
        <div style="display:flex; gap:0.875rem; flex-wrap:wrap;">
          <a href="/contact" class="btn-primary" style="font-size:0.9375rem;">Book the Call</a>
          <a href="/about-us" class="btn-outline" style="font-size:0.9375rem;">About Ferenc</a>
        </div>
      </div>

      <div style="display:flex; flex-direction:column; gap:1.25rem;">
        {[
          ['Tell me your situation', 'Briefly describe the challenge or opportunity you are facing.'],
          ['We talk', 'A 30-minute call — no slides, no pitch. Just an honest conversation.'],
          ['A clear next step', 'Either a proposed engagement or a frank "this isn\'t the right fit".'],
        ].map(([title, body], i) => (
          <div style="display:flex; gap:1.25rem; align-items:flex-start;">
            <span style="font-family:'Newsreader',Georgia,serif; font-size:1.5rem; font-weight:600; color:#C8CAC5; flex-shrink:0; line-height:1; margin-top:0.1rem;">
              {String(i + 1).padStart(2, '0')}
            </span>
            <div>
              <p style="font-weight:600; color:#18191A; margin:0 0 0.25rem; font-size:0.9375rem;">{title}</p>
              <p style="font-size:0.875rem; color:#5A5D5A; margin:0; line-height:1.65;">{body}</p>
            </div>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════ BOTTOM CTA -->
  <section style="background:#18191A; padding:5rem 1.5rem; text-align:center;">
    <div style="max-width:560px; margin:0 auto;">
      <p class="eyebrow" style="color:#2A5C34; margin:0 0 1.25rem;">Overcome Your Obstacles</p>
      <h2 style="font-family:'Newsreader',Georgia,serif; font-size:clamp(1.6rem,3vw,2.25rem); font-weight:600; color:#FAFAF7; line-height:1.25; margin:0 0 2rem;">
        The right programme for your situation exists. Let's find it.
      </h2>
      <a
        href="/contact"
        style="padding:0.9rem 2.25rem; background:#2A5C34; color:#FAFAF7; font-size:1rem; font-weight:600; text-decoration:none; border-radius:3px; display:inline-block; transition:background-color 0.2s;"
        onmouseover="this.style.backgroundColor='#3D7048'"
        onmouseout="this.style.backgroundColor='#2A5C34'"
      >
        Get in Touch
      </a>
    </div>
  </section>

</Layout>

<style>
  @media (max-width: 860px) {
    article[style*="grid-template-columns:1fr 2fr"] {
      grid-template-columns: 1fr !important;
    }
    div[style*="grid-template-columns:1fr 1fr"] {
      grid-template-columns: 1fr !important;
      gap: 2.5rem !important;
    }
  }
</style>
