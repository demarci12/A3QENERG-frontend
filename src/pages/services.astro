---
import Layout from '../layouts/Layout.astro';

const services = [
  {
    id: 'roadmap',
    title: 'Roadmap',
    eyebrow: 'Strategic Planning',
    summary: 'A structured diagnostic and strategic roadmap process that reveals where your organisation truly is — and charts the most credible path forward.',
    details: [
      'Peer-to-peer executive interviews to surface the real strategic picture',
      'Three alternative scenario development with risk-weighted trade-off analysis',
      'Synthesis into a prioritised, actionable roadmap with ownership and milestones',
    ],
    duration: '4 – 8 weeks',
  },
  {
    id: 'mentoring',
    title: 'Mentoring',
    eyebrow: 'Leadership Development',
    summary: 'A high-intensity, individually tailored mentoring engagement for current and aspiring energy sector leaders — built on candour, challenge, and commitment.',
    details: [
      'Structured programme of 1-on-1 sessions bi-weekly or monthly',
      'Deep-dive into leadership style, decision-making patterns, and stakeholder navigation',
      'Real-time coaching on live challenges you are currently facing',
    ],
    duration: '6 weeks – 3 months',
  },
  {
    id: 'leadership-on-top',
    title: 'Leadership on Top',
    eyebrow: 'Executive Team',
    summary: 'Senior leadership teams that are technically capable but not functioning as a unit. This programme closes the gap between individual excellence and collective performance.',
    details: [
      'Executive team diagnostic: alignment, trust, and decision quality assessment',
      'Facilitated offsite with structured conflict-and-commitment protocols',
      'Follow-on coaching to embed new operating rhythms',
    ],
    duration: '3 – 6 months',
  },
  {
    id: 'multigenerational',
    title: 'Multiple Generation Management',
    eyebrow: 'Workforce',
    summary: 'Turning generational diversity from a friction point into a genuine organisational capability. Practical, not theoretical.',
    details: [
      'Generational profile of your workforce and knowledge-flow audit',
      'Leadership workshop: understanding each generation\'s operating logic',
      'Structural interventions: mentoring pairs, project team design, succession frameworks',
    ],
    duration: '4 – 12 weeks',
  },
  {
    id: 'leaders-for-safety',
    title: 'Leaders for Safety',
    eyebrow: 'Safety Culture',
    summary: 'Safety performance is a leadership problem before it is an operational one. This programme builds the mindsets and behaviours that define a genuine zero-harm culture.',
    details: [
      'Safety culture diagnostic across leadership and frontline levels',
      'Executive safety leadership workshop: from compliance to conviction',
      'Behaviour-based safety coaching for senior leaders and line managers',
    ],
    duration: '6 – 12 weeks',
  },
  {
    id: 'esg',
    title: 'ESG on Focus',
    eyebrow: 'Sustainability Strategy',
    summary: 'From reporting obligation to strategic asset. This engagement helps energy organisations build ESG into the core of how they operate and compete.',
    details: [
      'ESG materiality assessment aligned with CSRD and TCFD frameworks',
      'Gap analysis between current practices and disclosure requirements',
      'Integration roadmap: embedding ESG into strategy, operations, and capital allocation',
    ],
    duration: '6 – 16 weeks',
  },
];
---

<Layout
  title="Services — A3QENERG"
  description="Executive advisory services: strategy roadmaps, leadership mentoring, safety culture, multigenerational management, and ESG integration."
>

  <!-- ═══════════════════════════════════════════════════════ PAGE HERO -->
  <section style="padding:5rem 1.5rem 4rem; max-width:1200px; margin:0 auto;">
    <div style="max-width:700px;">
      <p style="font-size:0.75rem; text-transform:uppercase; letter-spacing:0.14em; color:#2E5233; margin-bottom:1rem; font-weight:600;">
        What We Offer
      </p>
      <h1 style="font-family:'Newsreader',Georgia,serif; font-size:clamp(2rem,4.5vw,3rem); font-weight:700; color:#173b1e; line-height:1.2; margin-bottom:1.25rem;">
        Overcome your obstacles.<br />Get Business Coaching, Today!
      </h1>
      <p style="font-size:1.0625rem; color:#3d3f3d; line-height:1.75; max-width:600px;">
        Each engagement is designed to generate real decisions, real capability, and real results — not slide decks that sit on shelves. Select the programme that fits your situation, or combine them for a comprehensive transformation partnership.
      </p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════ DIVIDER -->
  <div style="border-top:1px solid #e7e8e7; max-width:1200px; margin:0 auto;"></div>

  <!-- ═══════════════════════════════════════════════════════ SERVICES GRID -->
  <section style="padding:4rem 1.5rem; max-width:1200px; margin:0 auto;">
    <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(320px,1fr)); gap:2rem;">
      {services.map((s) => (
        <article
          id={s.id}
          style="padding:2rem; border:1px solid #e7e8e7; border-radius:6px; display:flex; flex-direction:column; gap:1rem;"
        >
          <!-- Eyebrow + duration -->
          <div style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:0.5rem;">
            <p style="font-size:0.7rem; text-transform:uppercase; letter-spacing:0.1em; color:#2E5233; font-weight:600; margin:0;">
              {s.eyebrow}
            </p>
            <span style="font-size:0.7rem; color:#c8cac8; background:#e7e8e7; padding:0.15rem 0.5rem; border-radius:3px;">
              {s.duration}
            </span>
          </div>

          <!-- Title -->
          <h2 style="font-family:'Newsreader',Georgia,serif; font-size:1.375rem; font-weight:700; color:#173b1e; margin:0; line-height:1.25;">
            {s.title}
          </h2>

          <!-- Summary -->
          <p style="font-size:0.9375rem; color:#3d3f3d; line-height:1.7; margin:0;">
            {s.summary}
          </p>

          <!-- Details list -->
          <ul style="list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:0.5rem; flex:1;">
            {s.details.map((d) => (
              <li style="display:flex; gap:0.6rem; font-size:0.875rem; color:#3d3f3d; line-height:1.6;">
                <span style="color:#2E5233; flex-shrink:0; font-weight:700; margin-top:0.1rem;">—</span>
                <span>{d}</span>
              </li>
            ))}
          </ul>

          <!-- CTA -->
          <div style="margin-top:auto; padding-top:1rem; border-top:1px solid #e7e8e7;">
            <a
              href="/contact"
              style="display:inline-block; padding:0.55rem 1.1rem; font-size:0.875rem; font-weight:600; color:#f9f9f8; background-color:#2E5233; text-decoration:none; border-radius:4px; transition:background-color 0.2s;"
              onmouseover="this.style.backgroundColor='#173b1e'"
              onmouseout="this.style.backgroundColor='#2E5233'"
            >
              Enquire →
            </a>
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════ BOOKING SECTION -->
  <section style="background-color:#f0f2f0; padding:5rem 1.5rem;">
    <div style="max-width:1200px; margin:0 auto;">

      <div style="max-width:560px; margin-bottom:2.5rem;">
        <p style="font-size:0.75rem; text-transform:uppercase; letter-spacing:0.14em; color:#2E5233; margin-bottom:1rem; font-weight:600;">
          Direct Booking
        </p>
        <h2 style="font-family:'Newsreader',Georgia,serif; font-size:clamp(1.6rem,3vw,2rem); font-weight:700; color:#173b1e; line-height:1.25; margin-bottom:1rem;">
          Book a Discovery Call
        </h2>
        <p style="font-size:0.9375rem; color:#3d3f3d; line-height:1.75;">
          A 30-minute, no-obligation conversation to understand your situation and explore whether there is a fit. Select a time that works for you below.
        </p>
      </div>

      <!-- Calendly placeholder -->
      <div
        style="
          background:#f9f9f8;
          border:1px dashed #c8cac8;
          border-radius:6px;
          padding:3rem;
          text-align:center;
          min-height:200px;
          display:flex;
          flex-direction:column;
          align-items:center;
          justify-content:center;
          gap:0.75rem;
        "
        id="calendly-embed"
      >
        <!-- Replace this placeholder block with your Calendly inline widget script -->
        <p style="font-size:0.875rem; color:#c8cac8; margin:0;">
          Calendly / scheduler embed goes here
        </p>
        <p style="font-size:0.75rem; color:#c8cac8; margin:0;">
          Paste your inline embed code into <code style="background:#e7e8e7; padding:0.1rem 0.4rem; border-radius:3px; color:#3d3f3d;">src/pages/services.astro</code> inside the <code style="background:#e7e8e7; padding:0.1rem 0.4rem; border-radius:3px; color:#3d3f3d;">#calendly-embed</code> div.
        </p>
        <a
          href="/contact"
          style="margin-top:0.5rem; padding:0.65rem 1.4rem; font-size:0.875rem; font-weight:600; color:#f9f9f8; background-color:#2E5233; text-decoration:none; border-radius:4px;"
        >
          Or use the contact form →
        </a>
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════ BOTTOM CTA -->
  <section style="padding:5rem 1.5rem; text-align:center; max-width:1200px; margin:0 auto;">
    <div style="max-width:560px; margin:0 auto;">
      <h2 style="font-family:'Newsreader',Georgia,serif; font-size:clamp(1.4rem,2.5vw,1.875rem); font-weight:700; color:#173b1e; line-height:1.25; margin-bottom:1rem;">
        Not sure which programme is right for you?
      </h2>
      <p style="font-size:1rem; color:#3d3f3d; line-height:1.7; margin-bottom:2rem;">
        Send a message describing your situation and I'll come back with a considered view on the best starting point.
      </p>
      <a
        href="/contact"
        style="display:inline-block; padding:0.875rem 2rem; background-color:#2E5233; color:#f9f9f8; font-size:1rem; font-weight:600; text-decoration:none; border-radius:4px; transition:background-color 0.2s;"
        onmouseover="this.style.backgroundColor='#173b1e'"
        onmouseout="this.style.backgroundColor='#2E5233'"
      >
        Get in Touch
      </a>
    </div>
  </section>

</Layout>
