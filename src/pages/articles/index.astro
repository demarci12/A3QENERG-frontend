---
import Layout from '../../layouts/Layout.astro';
import { formatDate, getAuthorName, getCategories, getPosts, stripHtml } from '../../utils/wordpress';

const posts = await getPosts(100);
---

<Layout
  title="Articles — A3QENERG"
  description="Strategic insights on energy transformation, leadership, ESG, and organisational performance by Ferenc Csulak."
>

  <!-- ═══════════════════════════════════════════════════════ HERO -->
  <section style="padding:5rem 1.5rem 4rem; max-width:1200px; margin:0 auto;">
    <div style="max-width:700px;">
      <p style="font-size:0.75rem; text-transform:uppercase; letter-spacing:0.14em; color:#2E5233; margin-bottom:1rem; font-weight:600;">
        The Archive
      </p>
      <h1 style="font-family:'Newsreader',Georgia,serif; font-size:clamp(2rem,4.5vw,3rem); font-weight:700; color:#173b1e; line-height:1.2; margin-bottom:1rem;">
        All Articles
      </h1>
      <p style="font-size:1.0625rem; color:#3d3f3d; line-height:1.7;">
        {posts.length} publication{posts.length !== 1 ? 's' : ''} on energy strategy, leadership, ESG, and transformation.
      </p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════ DIVIDER -->
  <div style="border-top:1px solid #e7e8e7; max-width:1200px; margin:0 auto;"></div>

  <!-- ═══════════════════════════════════════════════════════ ARTICLES LIST -->
  <section style="padding:4rem 1.5rem; max-width:1200px; margin:0 auto;">

    {posts.length === 0 ? (
      <p style="color:#c8cac8; font-size:1rem;">No articles yet. Check back soon.</p>
    ) : (
      <div style="display:flex; flex-direction:column; gap:0;">
        {posts.map((post, i) => (
          <article style={`display:grid; grid-template-columns:120px 1fr; gap:2rem; padding:2rem 0; border-bottom:1px solid #e7e8e7; align-items:start;`}>

            <!-- Date column -->
            <div style="padding-top:0.35rem;">
              <time
                datetime={post.date}
                style="font-size:0.8125rem; color:#c8cac8; line-height:1.4; display:block;"
              >
                {formatDate(post.date, 'en-GB')}
              </time>
            </div>

            <!-- Content column -->
            <div>
              {getCategories(post)[0] && (
                <p style="font-size:0.7rem; text-transform:uppercase; letter-spacing:0.1em; color:#2E5233; margin:0 0 0.5rem; font-weight:600;">
                  {getCategories(post)[0]}
                </p>
              )}
              <h2 style="font-family:'Newsreader',Georgia,serif; font-size:1.375rem; font-weight:700; color:#173b1e; margin:0 0 0.65rem; line-height:1.25;">
                <a
                  href={`/articles/${post.slug}`}
                  style="text-decoration:none; color:inherit; transition:color 0.2s;"
                  onmouseover="this.style.color='#2E5233'"
                  onmouseout="this.style.color='#173b1e'"
                >
                  {post.title.rendered}
                </a>
              </h2>
              <p style="font-size:0.9375rem; color:#3d3f3d; line-height:1.7; margin:0 0 0.75rem; max-width:600px;">
                {stripHtml(post.excerpt.rendered).slice(0, 200)}…
              </p>
              <a
                href={`/articles/${post.slug}`}
                style="font-size:0.875rem; color:#2E5233; text-decoration:none; font-weight:600;"
              >
                Read article →
              </a>
            </div>

          </article>
        ))}
      </div>
    )}

  </section>

  <!-- ═══════════════════════════════════════════════════════ NEWSLETTER / LEAD CTA -->
  <section style="border-top:1px solid #e7e8e7; padding:5rem 1.5rem; text-align:center; background-color:#f9f9f8;">
    <div style="max-width:540px; margin:0 auto;">
      <p style="font-size:0.75rem; text-transform:uppercase; letter-spacing:0.14em; color:#2E5233; margin-bottom:1rem; font-weight:600;">
        Never Miss a Publication
      </p>
      <h2 style="font-family:'Newsreader',Georgia,serif; font-size:clamp(1.4rem,2.5vw,1.875rem); font-weight:700; color:#173b1e; line-height:1.25; margin-bottom:1rem;">
        Get the Free Energy Audit Guide
      </h2>
      <p style="font-size:0.9375rem; color:#3d3f3d; line-height:1.7; margin-bottom:2rem;">
        A practitioner's framework for transformation readiness, free to download.
      </p>
      <a
        href="/#lead-magnet"
        style="display:inline-block; padding:0.8rem 1.75rem; background-color:#2E5233; color:#f9f9f8; font-size:0.9375rem; font-weight:600; text-decoration:none; border-radius:4px; transition:background-color 0.2s;"
        onmouseover="this.style.backgroundColor='#173b1e'"
        onmouseout="this.style.backgroundColor='#2E5233'"
      >
        Download Free Guide
      </a>
    </div>
  </section>

</Layout>

<style>
  /* Responsive: collapse the date column on small screens */
  @media (max-width: 600px) {
    article {
      grid-template-columns: 1fr !important;
      gap: 0.5rem !important;
    }
  }
</style>
