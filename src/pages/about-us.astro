---
import { Image } from 'astro:assets';
import ferencPhoto from '../assets/ferenc-csulak.png';
import Timeline from '../components/Timeline.astro';
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="About Us — A3QENERG"
  description="Supporting for excellence and mentoring for Champions! Learn about Ferenc Csulak — Founder & CEO of A3QENERG, energy industry executive and business coach."
>

  <!-- ═══════════════════════════════════════════════════════ PAGE HERO -->
  <section style="padding:5rem 1.5rem 4rem; max-width:1200px; margin:0 auto;">
    <div style="max-width:760px;">
      <p style="font-size:0.75rem; text-transform:uppercase; letter-spacing:0.14em; color:#2E5233; margin-bottom:1rem; font-weight:600;">
        About Us
      </p>
      <h1 style="font-family:'Newsreader',Georgia,serif; font-size:clamp(2rem,4.5vw,3rem); font-weight:700; color:#173b1e; line-height:1.2; margin-bottom:0;">
        Supporting for excellence and mentoring for Champions!
      </h1>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════ DIVIDER -->
  <div style="border-top:1px solid #e7e8e7; max-width:1200px; margin:0 auto;"></div>

  <!-- ═══════════════════════════════════════════════════════ MISSION / VISION -->
  <section style="padding:4rem 1.5rem; max-width:1200px; margin:0 auto;">
    <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(280px,1fr)); gap:3rem;">

      <!-- Mission -->
      <div>
        <p style="font-size:0.75rem; text-transform:uppercase; letter-spacing:0.14em; color:#2E5233; margin-bottom:1rem; font-weight:600;">
          Mission
        </p>
        <blockquote style="font-family:'Newsreader',Georgia,serif; font-style:italic; font-size:1.2rem; color:#173b1e; border-left:3px solid #2E5233; padding-left:1.25rem; margin:0; line-height:1.65;">
          "Giving back to our societies the know-how gathered and experienced, being part of more educated and prepared society for the existing and upcoming challenges!"
        </blockquote>
      </div>

      <!-- Vision -->
      <div>
        <p style="font-size:0.75rem; text-transform:uppercase; letter-spacing:0.14em; color:#2E5233; margin-bottom:1rem; font-weight:600;">
          Vision
        </p>
        <blockquote style="font-family:'Newsreader',Georgia,serif; font-style:italic; font-size:1.2rem; color:#173b1e; border-left:3px solid #2E5233; padding-left:1.25rem; margin:0; line-height:1.65;">
          "Living in a sustainable, resilient less anxious more cooperative and fair world!"
        </blockquote>
      </div>

      <!-- Core Philosophy -->
      <div>
        <p style="font-size:0.75rem; text-transform:uppercase; letter-spacing:0.14em; color:#2E5233; margin-bottom:1rem; font-weight:600;">
          Core Philosophy
        </p>
        <blockquote style="font-family:'Newsreader',Georgia,serif; font-style:italic; font-size:1.2rem; color:#173b1e; border-left:3px solid #2E5233; padding-left:1.25rem; margin:0; line-height:1.65;">
          "We believe in the journey of excellence through learning and fun!"
        </blockquote>
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════ ORGANISATION PURPOSE -->
  <section style="background-color:#f0f2f0; padding:4rem 1.5rem;">
    <div style="max-width:1200px; margin:0 auto; max-width:760px;">
      <p style="font-size:0.75rem; text-transform:uppercase; letter-spacing:0.14em; color:#2E5233; margin-bottom:1.25rem; font-weight:600;">
        What We Do
      </p>
      <p style="font-family:'Newsreader',Georgia,serif; font-size:clamp(1.1rem,2.5vw,1.35rem); color:#173b1e; line-height:1.75;">
        We activate specialists across Europe to provide support, inspire new ideas, enhance client strengths, and achieve better performance while reducing wasted energy, time, and goods.
        Fun and joy are prerequisites — not afterthoughts — in everything we deliver.
      </p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════ FOUNDER PROFILE -->
  <section style="padding:4rem 1.5rem; max-width:1200px; margin:0 auto;">
    <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(280px,1fr)); gap:4rem; align-items:start;">

      <!-- Portrait -->
      <div style="position:relative; max-width:380px; border-radius:6px; overflow:hidden;">
        <Image
          src={ferencPhoto}
          alt="Ferenc Csulak — Founder & CEO, A3QENERG"
          width={760}
          height={720}
          style="width:100%; height:auto; display:block; object-fit:cover; object-position:center top;"
          loading="eager"
        />
        <div style="position:absolute; bottom:0; left:0; right:0; padding:1.25rem 1.5rem; background:linear-gradient(to top,rgba(23,59,30,0.92) 0%,transparent 100%);">
          <p style="font-family:'Newsreader',Georgia,serif; font-size:1.2rem; font-weight:700; color:#f9f9f8; margin:0;">Ferenc Csulak</p>
          <p style="font-size:0.8125rem; color:#c8cac8; margin:0.2rem 0 0;">Founder / CEO — A3QENERG</p>
        </div>
      </div>

      <!-- Bio -->
      <div>
        <p style="font-size:0.75rem; text-transform:uppercase; letter-spacing:0.14em; color:#2E5233; margin-bottom:1rem; font-weight:600;">
          Founder Profile
        </p>
        <h2 style="font-family:'Newsreader',Georgia,serif; font-size:1.875rem; font-weight:700; color:#173b1e; margin-bottom:1.25rem; line-height:1.25;">
          Ferenc Csulak
        </h2>
        <p style="font-size:0.9375rem; color:#3d3f3d; line-height:1.8; margin-bottom:1rem;">
          Experienced Executive Officer with a demonstrated history in the utilities industry. Long experience in European energy markets — gas and power, especially East Europe — with deep expertise in HSE and ESG.
        </p>
        <p style="font-size:0.9375rem; color:#3d3f3d; line-height:1.8; margin-bottom:1rem;">
          Skilled in leadership, business performance, general management, and mentoring. Currently serving as General Manager of Delgaz Grid, one of Romania's largest gas and power distribution network operators.
        </p>
        <p style="font-size:0.9375rem; color:#3d3f3d; line-height:1.8;">
          Through A3QENERG, Ferenc channels two decades of executive field experience into advisory work, mentoring programmes, and published insights — giving back to the sector the knowledge gathered over a career spent at the frontier of European energy transformation.
        </p>

        <!-- Quick stats -->
        <div style="display:flex; flex-wrap:wrap; gap:1.5rem; margin-top:2rem; padding-top:2rem; border-top:1px solid #e7e8e7;">
          {[
            ['20+', 'Years in Energy'],
            ['6', 'Executive Roles'],
            ['3', 'Countries'],
            ['2', 'Languages'],
          ].map(([num, label]) => (
            <div>
              <p style="font-family:'Newsreader',Georgia,serif; font-size:2rem; font-weight:700; color:#2E5233; margin:0; line-height:1;">{num}</p>
              <p style="font-size:0.75rem; color:#c8cac8; margin:0.2rem 0 0; text-transform:uppercase; letter-spacing:0.08em;">{label}</p>
            </div>
          ))}
        </div>
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════ CAREER TIMELINE -->
  <section style="border-top:1px solid #e7e8e7; padding:4rem 1.5rem; max-width:1200px; margin:0 auto;">
    <div style="display:grid; grid-template-columns:1fr min(540px,100%); gap:4rem; align-items:start;">

      <div style="max-width:340px;">
        <p style="font-size:0.75rem; text-transform:uppercase; letter-spacing:0.14em; color:#2E5233; margin-bottom:1rem; font-weight:600;">
          Career Journey
        </p>
        <h2 style="font-family:'Newsreader',Georgia,serif; font-size:2rem; font-weight:700; color:#173b1e; line-height:1.25; margin-bottom:1.25rem;">
          A Record Built Across Europe's Energy Sector
        </h2>
        <p style="font-size:0.9375rem; color:#3d3f3d; line-height:1.75;">
          From Department Leader to General Manager — each role brought new regulatory environments, new teams, and new transformation challenges. The throughline is a consistent commitment to operational excellence and people development.
        </p>
      </div>

      <div>
        <Timeline />
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════ CTA -->
  <section style="background:linear-gradient(135deg,#2E5233,#173b1e); padding:5rem 1.5rem; text-align:center;">
    <div style="max-width:600px; margin:0 auto;">
      <h2 style="font-family:'Newsreader',Georgia,serif; font-size:clamp(1.6rem,3.5vw,2.4rem); font-weight:700; color:#f9f9f8; line-height:1.25; margin-bottom:2rem;">
        Overcome your obstacles.<br />Get from our services the most suitable for you!
      </h2>
      <div style="display:flex; flex-wrap:wrap; justify-content:center; gap:0.75rem;">
        <a
          href="/services"
          style="padding:0.9rem 2rem; background-color:#f9f9f8; color:#173b1e; font-size:1rem; font-weight:700; text-decoration:none; border-radius:4px; transition:background-color 0.2s;"
          onmouseover="this.style.backgroundColor='#e7e8e7'"
          onmouseout="this.style.backgroundColor='#f9f9f8'"
        >
          Explore Services
        </a>
        <a
          href="/contact"
          style="padding:0.9rem 2rem; background-color:transparent; color:#f9f9f8; font-size:1rem; font-weight:700; text-decoration:none; border-radius:4px; border:1.5px solid rgba(255,255,255,0.4); transition:border-color 0.2s;"
          onmouseover="this.style.borderColor='rgba(255,255,255,0.9)'"
          onmouseout="this.style.borderColor='rgba(255,255,255,0.4)'"
        >
          Contact Us
        </a>
      </div>
    </div>
  </section>

</Layout>
