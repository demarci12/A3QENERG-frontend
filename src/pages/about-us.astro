---
import { Image } from 'astro:assets';
import ferencPhoto from '../assets/ferenc-csulak.png';
import Timeline from '../components/Timeline.astro';
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="About Ferenc Csulak — Energy & Leadership Advisor"
  description="40 years in European energy. Executive leader, strategic advisor, and author. Founder of A3QENERG."
>

  <!-- ═══════════════════════════════════════════════════ HERO -->
  <section style="padding:6rem 1.5rem 5rem; max-width:1160px; margin:0 auto;">
    <div style="display:grid; grid-template-columns:1fr auto; gap:5rem; align-items:start;">

      <div style="max-width:620px;">
        <p class="eyebrow" style="margin:0 0 1.5rem;">About</p>
        <h1 style="font-family:'Newsreader',Georgia,serif; font-size:clamp(2.25rem,5vw,3.5rem); font-weight:600; color:#18191A; line-height:1.15; margin:0 0 2rem; letter-spacing:-0.01em;">
          I have spent my career<br />
          <em style="color:#2A5C34; font-style:italic;">inside the machine.</em>
        </h1>
        <p style="font-size:1.125rem; color:#5A5D5A; line-height:1.8; margin:0 0 1.25rem;">
          As a General Manager and CEO across some of Europe's largest energy networks,
          I did not observe transformation from the outside — I led it, lived it,
          and was accountable for it.
        </p>
        <p style="font-size:1.125rem; color:#5A5D5A; line-height:1.8; margin:0;">
          Today, through A3QENERG, I put that experience at the service of executives
          and organisations that are navigating the same pressures I know first-hand.
        </p>
      </div>

      <div class="about-portrait" style="flex-shrink:0;">
        <div style="width:280px; height:340px; border-radius:4px; overflow:hidden; border:1px solid #E4E5E2;">
          <Image
            src={ferencPhoto}
            alt="Ferenc Csulak"
            width={560}
            height={680}
            style="width:100%; height:100%; object-fit:cover; object-position:center top; display:block;"
            loading="eager"
          />
        </div>
        <div style="margin-top:1.25rem; padding:1.25rem; background:#F3F4F1; border-radius:3px;">
          <p style="font-family:'Newsreader',Georgia,serif; font-size:1rem; font-weight:600; color:#18191A; margin:0 0 0.2rem;">Ferenc Csulak</p>
          <p style="font-size:0.75rem; text-transform:uppercase; letter-spacing:0.12em; color:#2A5C34; margin:0; font-weight:500;">Founder, A3QENERG</p>
        </div>
      </div>

    </div>
  </section>

  <hr class="divider" style="max-width:1160px; margin:0 auto;" />

  <!-- ═══════════════════════════════════════════════════ PHILOSOPHY -->
  <section style="padding:5rem 1.5rem; max-width:1160px; margin:0 auto;">
    <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:1px; background:#E4E5E2; border:1px solid #E4E5E2; border-radius:4px; overflow:hidden;">

      {[
        {
          label: 'Mission',
          quote: '"Giving back to our societies the know-how gathered and experienced — being part of a more educated and prepared society for the existing and upcoming challenges."',
        },
        {
          label: 'Vision',
          quote: '"Living in a sustainable, resilient, less anxious, more cooperative and fair world."',
        },
        {
          label: 'Philosophy',
          quote: '"We believe in the journey of excellence through learning and fun."',
        },
      ].map(item => (
        <div style="padding:2.5rem; background:#FAFAF7;">
          <p class="eyebrow" style="margin:0 0 1.25rem;">{item.label}</p>
          <blockquote style="font-family:'Newsreader',Georgia,serif; font-style:italic; font-size:1.0625rem; color:#18191A; line-height:1.7; margin:0; border-left:2px solid #2A5C34; padding-left:1.125rem;">
            {item.quote}
          </blockquote>
        </div>
      ))}

    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════ BIO BODY -->
  <section style="background:#F3F4F1; padding:5rem 1.5rem;">
    <div style="max-width:1160px; margin:0 auto; display:grid; grid-template-columns:1fr 2fr; gap:5rem; align-items:start;">

      <!-- Stats -->
      <div style="position:sticky; top:80px;">
        <p class="eyebrow" style="margin:0 0 2rem;">By the Numbers</p>
        {[
          ['40+', 'Years in the energy sector'],
          ['6',   'Executive and C-suite roles'],
          ['5',   'Countries of operation'],
          ['3',   'Languages'],
          ['1M+', 'Customers served at peak'],
        ].map(([num, label]) => (
          <div style="padding:1.25rem 0; border-bottom:1px solid #E4E5E2;">
            <p style="font-family:'Newsreader',Georgia,serif; font-size:2rem; font-weight:600; color:#2A5C34; margin:0; line-height:1; letter-spacing:-0.02em;">{num}</p>
            <p style="font-size:0.8125rem; color:#5A5D5A; margin:0.25rem 0 0;">{label}</p>
          </div>
        ))}
      </div>

      <!-- Biography text -->
      <div>
        <p class="eyebrow" style="margin:0 0 1.5rem;">Biography</p>

        {[
          `Ferenc Csulak is a senior energy executive with over 40 years of experience across the European gas and power sector. He has held General Manager and CEO positions at Delgaz Grid, E.ON Hungária, and E.ON Közép-dunántúli Gázhálózati — organisations collectively serving millions of customers across Romania and Hungary.`,
          `His career spans the full arc of European energy transformation: from the privatisation era of the 1990s through the regulatory modernisation of the 2000s, to today's twin pressures of decarbonisation and energy security. He has operated in five countries, navigating distinct regulatory frameworks, cultures, and organisational contexts.`,
          `Ferenc brings deep expertise in HSE and safety culture, ESG governance, multi-generational workforce management, and strategic planning. He is fluent in English, Romanian, and Hungarian — a practical advantage in Central and Eastern European markets where cultural nuance shapes outcomes.`,
          `Through A3QENERG, he now channels this accumulated knowledge into advisory engagements, mentoring programmes, and published strategic commentary. His approach is direct, evidence-based, and built on the conviction that fun and genuine learning are not in opposition to high performance — they are its preconditions.`,
        ].map(para => (
          <p style="font-size:1.0625rem; color:#2A2B2A; line-height:1.85; margin:0 0 1.75rem;">{para}</p>
        ))}

        <div style="margin-top:2.5rem; padding:2rem; border:1px solid #E4E5E2; border-radius:3px; background:#FAFAF7;">
          <p style="font-family:'Newsreader',Georgia,serif; font-style:italic; font-size:1.125rem; color:#18191A; line-height:1.65; margin:0 0 1rem;">
            "We activate specialists across Europe to provide support, inspire new ideas, enhance client strengths, and achieve better performance — with less wasted energy, time, and resource."
          </p>
          <p style="font-size:0.8125rem; color:#9B9D9B; margin:0;">— Ferenc Csulak, Founder of A3QENERG</p>
        </div>

        <div style="margin-top:2.5rem; display:flex; gap:0.875rem; flex-wrap:wrap;">
          <a href="/contact" class="btn-primary" style="font-size:0.9375rem;">Book a Consultation</a>
          <a href="/articles" class="btn-outline" style="font-size:0.9375rem;">Read the Articles</a>
        </div>
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════ CAREER TIMELINE -->
  <section style="padding:5rem 1.5rem; max-width:1160px; margin:0 auto;">
    <div style="display:grid; grid-template-columns:1fr 2fr; gap:5rem; align-items:start;">

      <div style="position:sticky; top:80px;">
        <p class="eyebrow" style="margin:0 0 1rem;">Career</p>
        <h2 style="font-family:'Newsreader',Georgia,serif; font-size:clamp(1.5rem,3vw,2rem); font-weight:600; color:#18191A; line-height:1.25; margin:0 0 1.25rem;">
          A record built across Europe's energy sector.
        </h2>
        <p style="font-size:0.9375rem; color:#5A5D5A; line-height:1.75; margin:0 0 2rem;">
          From Department Leader to General Manager — each role brought new regulatory environments,
          new teams, and new transformation challenges.
        </p>
        <a href="/contact" class="btn-outline" style="font-size:0.875rem;">Work With Me →</a>
      </div>

      <div>
        <Timeline />
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════ CTA -->
  <section style="background:#18191A; padding:6rem 1.5rem; text-align:center;">
    <div style="max-width:580px; margin:0 auto;">
      <p class="eyebrow" style="color:#2A5C34; margin:0 0 1.25rem;">Work Together</p>
      <h2 style="font-family:'Newsreader',Georgia,serif; font-size:clamp(1.75rem,3.5vw,2.5rem); font-weight:600; color:#FAFAF7; line-height:1.2; margin:0 0 1.25rem;">
        Bring 40 years of energy expertise to your organisation.
      </h2>
      <p style="font-size:1rem; color:#9B9D9B; line-height:1.7; margin:0 0 2.5rem;">
        From a single strategy session to a multi-month engagement —
        find the format that fits your situation.
      </p>
      <div style="display:flex; flex-wrap:wrap; justify-content:center; gap:0.875rem;">
        <a
          href="/services"
          style="padding:0.9rem 2rem; background:#2A5C34; color:#FAFAF7; font-size:0.9375rem; font-weight:600; text-decoration:none; border-radius:3px; transition:background-color 0.2s;"
          onmouseover="this.style.backgroundColor='#3D7048'"
          onmouseout="this.style.backgroundColor='#2A5C34'"
        >
          Explore Services
        </a>
        <a
          href="/contact"
          style="padding:0.9rem 2rem; background:transparent; color:#E4E5E2; font-size:0.9375rem; font-weight:500; text-decoration:none; border-radius:3px; border:1px solid #2A2B2A; transition:border-color 0.2s;"
          onmouseover="this.style.borderColor='#5A5D5A'"
          onmouseout="this.style.borderColor='#2A2B2A'"
        >
          Get in Touch
        </a>
      </div>
    </div>
  </section>

</Layout>

<style>
  @media (max-width: 860px) {
    .about-portrait { display: none !important; }
  }
  @media (max-width: 680px) {
    div[style*="grid-template-columns:repeat(3,1fr)"] {
      grid-template-columns: 1fr !important;
    }
    div[style*="grid-template-columns:1fr 2fr"] {
      grid-template-columns: 1fr !important;
      gap: 2.5rem !important;
    }
    div[style*="position:sticky"] {
      position: static !important;
    }
  }
</style>
