---
import { Image } from 'astro:assets';
import ferencPhoto from '../assets/ferenc-csulak.png';
import Timeline from '../components/Timeline.astro';
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="About Us — A3QENERG"
  description="Learn about Ferenc Csulak — executive leader, energy transformation specialist, and champion of the next generation of industry leaders."
>

  <!-- ═══════════════════════════════════════════════════════ PAGE HERO -->
  <section style="padding:5rem 1.5rem 4rem; max-width:1200px; margin:0 auto;">
    <div style="max-width:720px;">

      <p style="font-size:0.75rem; text-transform:uppercase; letter-spacing:0.14em; color:#2E5233; margin-bottom:1rem; font-weight:600;">
        About Us
      </p>

      <h1 style="font-family:'Newsreader',Georgia,serif; font-size:clamp(2rem,4.5vw,3rem); font-weight:700; color:#173b1e; line-height:1.2; margin-bottom:1.5rem;">
        Supporting for excellence and mentoring for Champions!
      </h1>

      <p style="font-size:1.0625rem; color:#3d3f3d; line-height:1.75; max-width:600px;">
        A3QENERG is the personal brand of <strong>Ferenc Csulak</strong> — a seasoned energy industry executive with more than two decades of leadership across Romania, Hungary, and Central Europe. The platform exists to give back the knowledge gathered on the field.
      </p>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════ DIVIDER -->
  <div style="border-top:1px solid #e7e8e7; max-width:1200px; margin:0 auto;"></div>

  <!-- ═══════════════════════════════════════════════════════ VISION & MISSION -->
  <section style="padding:4rem 1.5rem; max-width:1200px; margin:0 auto;">
    <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(280px,1fr)); gap:3rem;">

      <!-- Vision -->
      <div>
        <p style="font-size:0.75rem; text-transform:uppercase; letter-spacing:0.14em; color:#2E5233; margin-bottom:1rem; font-weight:600;">
          Vision
        </p>
        <h2 style="font-family:'Newsreader',Georgia,serif; font-size:1.5rem; font-weight:700; color:#173b1e; margin-bottom:1rem; line-height:1.3;">
          A More Educated & Prepared Society
        </h2>
        <p style="font-size:0.9375rem; color:#3d3f3d; line-height:1.75;">
          To contribute to a world where organisations — and the people within them — are equipped to navigate the unprecedented complexity of the energy transition. By sharing knowledge, frameworks, and hard-won experience, A3QENERG aims to raise the standard of strategic thinking across the sector.
        </p>
      </div>

      <!-- Mission -->
      <div>
        <p style="font-size:0.75rem; text-transform:uppercase; letter-spacing:0.14em; color:#2E5233; margin-bottom:1rem; font-weight:600;">
          Mission
        </p>
        <h2 style="font-family:'Newsreader',Georgia,serif; font-size:1.5rem; font-weight:700; color:#173b1e; margin-bottom:1rem; line-height:1.3;">
          Giving Back Know-How from the Field
        </h2>
        <p style="font-size:0.9375rem; color:#3d3f3d; line-height:1.75;">
          To mentor current and emerging leaders in the energy sector; to provide strategic counsel that is grounded in real operational context rather than theory; and to publish insights that help practitioners make better decisions faster, with greater confidence.
        </p>
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════ ABOUT FERENC -->
  <section style="background-color:#f0f2f0; padding:4rem 1.5rem;">
    <div style="max-width:1200px; margin:0 auto; display:grid; grid-template-columns:repeat(auto-fit, minmax(280px,1fr)); gap:3rem; align-items:start;">

      <!-- Portrait -->
      <div style="position:relative; max-width:360px; border-radius:6px; overflow:hidden;">
        <Image
          src={ferencPhoto}
          alt="Ferenc Csulak — General Manager, Delgaz Grid"
          width={720}
          height={680}
          style="width:100%; height:auto; display:block; object-fit:cover; object-position:center top;"
          loading="eager"
        />
        <!-- Name overlay -->
        <div style="position:absolute; bottom:0; left:0; right:0; padding:1.25rem 1.5rem; background:linear-gradient(to top, rgba(23,59,30,0.92) 0%, transparent 100%);">
          <p style="font-family:'Newsreader',Georgia,serif; font-size:1.2rem; font-weight:700; color:#f9f9f8; margin:0;">Ferenc Csulak</p>
          <p style="font-size:0.8125rem; color:#c8cac8; margin:0.2rem 0 0;">General Manager, Delgaz Grid</p>
        </div>
      </div>

      <!-- Bio -->
      <div>
        <p style="font-size:0.75rem; text-transform:uppercase; letter-spacing:0.14em; color:#2E5233; margin-bottom:1rem; font-weight:600;">
          The Person Behind the Brand
        </p>
        <h2 style="font-family:'Newsreader',Georgia,serif; font-size:1.75rem; font-weight:700; color:#173b1e; margin-bottom:1.25rem; line-height:1.25;">
          Two Decades at the Intersection of Energy, Leadership & Transformation
        </h2>
        <div style="font-size:0.9375rem; color:#3d3f3d; line-height:1.8; display:flex; flex-direction:column; gap:1rem;">
          <p>
            Ferenc Csulak has spent his career leading distribution network operators at the frontier of Central and Eastern European energy transformation. From his early years at ÉDÁSZ RT through to the CEO roles at E.ON and his current leadership of Delgaz Grid, he has managed organisations through regulatory upheaval, infrastructure modernisation, and the first wave of the renewable transition.
          </p>
          <p>
            His leadership philosophy centres on three convictions: that operational discipline is the foundation of strategic agility; that safety culture is the most reliable leading indicator of organisational health; and that the most durable competitive advantage in the energy sector is the quality of an organisation's people and the speed at which they learn.
          </p>
          <p>
            Through A3QENERG, Ferenc channels these convictions into advisory work, mentoring, and the written word — seeking to accelerate the development of the next generation of energy leaders.
          </p>
        </div>
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════ CAREER TIMELINE -->
  <section style="padding:4rem 1.5rem; max-width:1200px; margin:0 auto;">
    <div style="display:grid; grid-template-columns:1fr min(560px,100%); gap:4rem; align-items:start;">

      <!-- Left label -->
      <div style="max-width:340px;">
        <p style="font-size:0.75rem; text-transform:uppercase; letter-spacing:0.14em; color:#2E5233; margin-bottom:1rem; font-weight:600;">
          Career Journey
        </p>
        <h2 style="font-family:'Newsreader',Georgia,serif; font-size:2rem; font-weight:700; color:#173b1e; line-height:1.25; margin-bottom:1.25rem;">
          A Record Built Across Europe's Energy Sector
        </h2>
        <p style="font-size:0.9375rem; color:#3d3f3d; line-height:1.75;">
          Each role brought new regulatory environments, new teams, and new transformation challenges. The throughline is a consistent commitment to operational excellence and people development.
        </p>
      </div>

      <!-- Timeline component -->
      <div>
        <Timeline />
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════ VALUES -->
  <section style="border-top:1px solid #e7e8e7; padding:4rem 1.5rem; max-width:1200px; margin:0 auto;">

    <p style="font-size:0.75rem; text-transform:uppercase; letter-spacing:0.14em; color:#2E5233; margin-bottom:2rem; font-weight:600;">
      Guiding Principles
    </p>

    <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(200px,1fr)); gap:2rem;">
      {[
        ['Operational Excellence', 'Reliability is earned daily through disciplined process, clear accountability, and a culture of continuous improvement.'],
        ['Safety First', 'A zero-harm culture is not a programme; it is the true measure of leadership credibility.'],
        ['Strategic Clarity', 'The best strategy is one that everyone in the organisation can explain in their own words.'],
        ['People Development', 'The half-life of technical knowledge is shrinking. The half-life of learning culture is not.'],
        ['ESG as Value Creation', 'Sustainability is not a constraint on performance; it is the lens through which durable performance is built.'],
        ['Knowledge Sharing', 'Experience that is not shared is experience wasted.'],
      ].map(([title, body]) => (
        <div style="padding:1.5rem; border:1px solid #e7e8e7; border-radius:6px;">
          <h3 style="font-family:'Newsreader',Georgia,serif; font-size:1.05rem; font-weight:700; color:#173b1e; margin:0 0 0.6rem; line-height:1.3;">{title}</h3>
          <p style="font-size:0.8125rem; color:#3d3f3d; line-height:1.65; margin:0;">{body}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════ CTA -->
  <section style="background:linear-gradient(135deg,#2E5233,#173b1e); padding:5rem 1.5rem; text-align:center;">
    <div style="max-width:560px; margin:0 auto;">
      <h2 style="font-family:'Newsreader',Georgia,serif; font-size:clamp(1.6rem,3vw,2.2rem); font-weight:700; color:#f9f9f8; line-height:1.25; margin-bottom:1.25rem;">
        Ready to work together?
      </h2>
      <p style="font-size:1rem; color:#e7e8e7; line-height:1.7; margin-bottom:2rem;">
        Explore the services or get in touch directly to discuss how we can work together on your transformation agenda.
      </p>
      <div style="display:flex; flex-wrap:wrap; justify-content:center; gap:0.75rem;">
        <a
          href="/services"
          style="padding:0.8rem 1.75rem; background-color:#f9f9f8; color:#173b1e; font-size:0.9375rem; font-weight:600; text-decoration:none; border-radius:4px; transition:background-color 0.2s;"
          onmouseover="this.style.backgroundColor='#e7e8e7'"
          onmouseout="this.style.backgroundColor='#f9f9f8'"
        >
          Explore Services
        </a>
        <a
          href="/contact"
          style="padding:0.8rem 1.75rem; background-color:transparent; color:#f9f9f8; font-size:0.9375rem; font-weight:600; text-decoration:none; border-radius:4px; border:1.5px solid rgba(255,255,255,0.4); transition:border-color 0.2s;"
          onmouseover="this.style.borderColor='rgba(255,255,255,0.8)'"
          onmouseout="this.style.borderColor='rgba(255,255,255,0.4)'"
        >
          Contact Us
        </a>
      </div>
    </div>
  </section>

</Layout>
