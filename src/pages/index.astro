---
import LeadMagnet from '../components/LeadMagnet.astro';
import Layout from '../layouts/Layout.astro';
import { formatDate, getAuthorName, getCategories, getPosts, stripHtml } from '../utils/wordpress';

const posts = await getPosts(20);
const [featured, ...archive] = posts;
---

<Layout
  title="A3QENERG — Strategic Insights on Energy Transformation"
  description="Strategic insights on energy transformation, leadership excellence, and ESG governance by Ferenc Csulak."
>

  <!-- ═══════════════════════════════════════════════════════ HERO -->
  <section style="padding: 5rem 1.5rem 4rem; max-width:1200px; margin:0 auto;">
    <div style="max-width:800px;">

      <!-- Eyebrow -->
      <p style="font-size:0.75rem; text-transform:uppercase; letter-spacing:0.14em; color:#2E5233; margin-bottom:1.25rem; font-weight:600;">
        Penned by Ferenc Csulak
      </p>

      <!-- Hero Title -->
      <h1 style="font-family:'Newsreader',Georgia,serif; font-size:clamp(2.2rem,5vw,3.5rem); font-weight:700; color:#173b1e; line-height:1.15; margin-bottom:1.5rem;">
        Strategic Insights on<br />Energy Transformation.
      </h1>

      <!-- Hero Quote -->
      <blockquote style="font-family:'Newsreader',Georgia,serif; font-style:italic; font-size:clamp(1rem,2vw,1.2rem); color:#3d3f3d; border-left:3px solid #2E5233; padding-left:1.25rem; margin:0 0 2rem; line-height:1.7; max-width:640px;">
        "Giving back to our societies the know-how gathered and experienced, being part of a more educated and prepared society for existing and upcoming challenges."
      </blockquote>

      <!-- CTA -->
      <div style="display:flex; flex-wrap:wrap; gap:0.75rem; align-items:center;">
        <a
          href="/contact"
          style="padding:0.8rem 1.75rem; background-color:#2E5233; color:#f9f9f8; font-size:0.9375rem; font-weight:600; text-decoration:none; border-radius:4px; transition:background-color 0.2s;"
          onmouseover="this.style.backgroundColor='#173b1e'"
          onmouseout="this.style.backgroundColor='#2E5233'"
        >
          Book Consultation
        </a>
        <a
          href="/articles"
          style="padding:0.8rem 1.75rem; background-color:transparent; color:#2E5233; font-size:0.9375rem; font-weight:600; text-decoration:none; border-radius:4px; border:1.5px solid #2E5233; transition:all 0.2s;"
          onmouseover="this.style.backgroundColor='#2E5233'; this.style.color='#f9f9f8';"
          onmouseout="this.style.backgroundColor='transparent'; this.style.color='#2E5233';"
        >
          Browse All Articles
        </a>
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════ DIVIDER -->
  <div style="border-top:1px solid #e7e8e7; max-width:1200px; margin:0 auto;"></div>

  <!-- ═══════════════════════════════════════════════════════ LATEST PUBLICATION -->
  {featured && (
    <section style="padding:4rem 1.5rem; max-width:1200px; margin:0 auto;">

      <p style="font-size:0.75rem; text-transform:uppercase; letter-spacing:0.14em; color:#2E5233; margin-bottom:2rem; font-weight:600;">
        Latest Publication
      </p>

      <a
        href={`/articles/${featured.slug}`}
        style="display:block; text-decoration:none; color:inherit; max-width:760px;"
      >
        <!-- Category chips -->
        {getCategories(featured).map(cat => (
          <span style="display:inline-block; font-size:0.7rem; text-transform:uppercase; letter-spacing:0.1em; background:#e7e8e7; color:#2E5233; padding:0.2rem 0.6rem; border-radius:3px; margin-right:0.4rem; margin-bottom:0.75rem; font-weight:600;">
            {cat}
          </span>
        ))}

        <!-- Title -->
        <h2 style="font-family:'Newsreader',Georgia,serif; font-size:clamp(1.6rem,3.5vw,2.4rem); font-weight:700; color:#173b1e; line-height:1.2; margin:0 0 1rem;">
          {featured.title.rendered}
        </h2>

        <!-- Excerpt -->
        <p style="font-size:1.0625rem; color:#3d3f3d; line-height:1.7; margin-bottom:1.25rem; max-width:640px;">
          {stripHtml(featured.excerpt.rendered).slice(0, 240)}…
        </p>

        <!-- Meta -->
        <div style="display:flex; align-items:center; gap:1rem; font-size:0.8125rem; color:#c8cac8;">
          <span>{getAuthorName(featured)}</span>
          <span aria-hidden="true">·</span>
          <time datetime={featured.date}>{formatDate(featured.date)}</time>
          <span style="color:#2E5233; font-weight:600;">Read →</span>
        </div>
      </a>
    </section>
  )}

  <!-- ═══════════════════════════════════════════════════════ LEAD MAGNET -->
  <LeadMagnet />

  <!-- ═══════════════════════════════════════════════════════ THE ARCHIVE -->
  {archive.length > 0 && (
    <section style="padding:4rem 1.5rem; max-width:1200px; margin:0 auto;">

      <div style="display:flex; justify-content:space-between; align-items:baseline; margin-bottom:2.5rem; flex-wrap:wrap; gap:1rem;">
        <p style="font-size:0.75rem; text-transform:uppercase; letter-spacing:0.14em; color:#2E5233; font-weight:600; margin:0;">
          The Archive
        </p>
        <a href="/articles" style="font-size:0.875rem; color:#2E5233; text-decoration:none; font-weight:600;">
          View all →
        </a>
      </div>

      <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(300px,1fr)); gap:2rem;">
        {archive.slice(0, 6).map((post) => (
          <article>
            <a
              href={`/articles/${post.slug}`}
              style="display:block; text-decoration:none; color:inherit; padding:1.75rem; border:1px solid #e7e8e7; border-radius:6px; transition:border-color 0.2s, box-shadow 0.2s; height:100%;"
              onmouseover="this.style.borderColor='#2E5233'; this.style.boxShadow='0 4px 20px rgba(46,82,51,0.08)';"
              onmouseout="this.style.borderColor='#e7e8e7'; this.style.boxShadow='none';"
            >
              <!-- Category -->
              {getCategories(post)[0] && (
                <p style="font-size:0.7rem; text-transform:uppercase; letter-spacing:0.1em; color:#2E5233; margin:0 0 0.75rem; font-weight:600;">
                  {getCategories(post)[0]}
                </p>
              )}

              <!-- Title -->
              <h3 style="font-family:'Newsreader',Georgia,serif; font-size:1.2rem; font-weight:700; color:#173b1e; line-height:1.3; margin:0 0 0.75rem;">
                {post.title.rendered}
              </h3>

              <!-- Excerpt -->
              <p style="font-size:0.875rem; color:#3d3f3d; line-height:1.65; margin:0 0 1.25rem;">
                {stripHtml(post.excerpt.rendered).slice(0, 140)}…
              </p>

              <!-- Meta -->
              <div style="font-size:0.75rem; color:#c8cac8; margin-top:auto;">
                <time datetime={post.date}>{formatDate(post.date)}</time>
              </div>
            </a>
          </article>
        ))}
      </div>

    </section>
  )}

  <!-- ═══════════════════════════════════════════════════════ HOME CTA BAND -->
  <section style="background-color:#f9f9f8; border-top:1px solid #e7e8e7; padding:5rem 1.5rem; text-align:center;">
    <div style="max-width:600px; margin:0 auto;">
      <p style="font-size:0.75rem; text-transform:uppercase; letter-spacing:0.14em; color:#2E5233; font-weight:600; margin-bottom:1rem;">
        Executive Advisory
      </p>
      <h2 style="font-family:'Newsreader',Georgia,serif; font-size:clamp(1.6rem,3.5vw,2.2rem); font-weight:700; color:#173b1e; line-height:1.2; margin-bottom:1.25rem;">
        Overcome your obstacles.<br />Get Consultation, Today!
      </h2>
      <p style="font-size:1rem; color:#3d3f3d; line-height:1.7; margin-bottom:2rem;">
        Whether you're navigating a grid transformation, building leadership capability, or embedding ESG into strategy — let's talk.
      </p>
      <a
        href="/contact"
        style="display:inline-block; padding:0.875rem 2rem; background-color:#2E5233; color:#f9f9f8; font-size:1rem; font-weight:600; text-decoration:none; border-radius:4px; transition:background-color 0.2s;"
        onmouseover="this.style.backgroundColor='#173b1e'"
        onmouseout="this.style.backgroundColor='#2E5233'"
      >
        Book Consultation
      </a>
    </div>
  </section>

</Layout>
