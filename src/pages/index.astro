---
import { Image } from 'astro:assets';
import ferencPhoto from '../assets/ferenc-csulak.png';
import LeadMagnet from '../components/LeadMagnet.astro';
import Layout from '../layouts/Layout.astro';
import { formatDate, getCategories, getPosts, stripHtml } from '../utils/wordpress';

const posts = await getPosts(20);
const recentPosts = posts.slice(0, 3);

const focusAreas = [
  {
    n: '01',
    title: 'Strategic Roadmaps',
    body: 'From vision to execution — I guide leadership teams through building mid- and long-term roadmaps that create clarity, alignment, and momentum.',
    href: '/services#roadmap',
  },
  {
    n: '02',
    title: 'Executive Leadership',
    body: 'A new toolkit for middle and senior managers — practical frameworks proven across five countries and six executive roles in European utilities.',
    href: '/services#leadership-on-top',
  },
  {
    n: '03',
    title: 'ESG & Sustainability',
    body: 'Translate EU sustainability requirements into a real ESG strategy. From gap analysis to implementation across your organisational units.',
    href: '/services#esg',
  },
];
---

<Layout
  title="Ferenc Csulak — Energy & Leadership Advisor"
  description="40 years in European energy. I help executives and organisations navigate transformation, build resilient leadership, and achieve lasting performance."
>

  <!-- ═══════════════════════════════════════════════════ HERO -->
  <section style="padding: 6rem 1.5rem 5rem; max-width: 1160px; margin: 0 auto;">
    <div style="display: grid; grid-template-columns: 1fr auto; gap: 4rem; align-items: center;">

      <div style="max-width: 680px;">

        <!-- Eyebrow -->
        <p class="eyebrow" style="margin: 0 0 1.75rem;">
          Energy Industry · Leadership · ESG
        </p>

        <!-- Headline -->
        <h1 style="font-family:'Newsreader',Georgia,serif; font-size:clamp(2.25rem,5vw,3.5rem); font-weight:600; color:#18191A; line-height:1.18; margin:0 0 1.5rem; letter-spacing:-0.01em;">
          Forty years building<br />
          <em style="color:#2A5C34; font-style:italic;">Europe's energy future.</em>
        </h1>

        <!-- Sub-headline -->
        <p style="font-size:clamp(1.0625rem,2.2vw,1.25rem); color:#5A5D5A; line-height:1.7; margin:0 0 2.5rem; max-width:560px;">
          I advise executives and organisations on strategic transformation,
          leadership excellence, and ESG governance — drawing on decades
          at the helm of some of Europe's largest energy networks.
        </p>

        <!-- CTAs -->
        <div style="display:flex; flex-wrap:wrap; gap:0.875rem; align-items:center;">
          <a
            href="/contact"
            class="btn-primary"
            style="font-size:1rem; padding:0.875rem 2rem;"
          >
            Book a Consultation
          </a>
          <a
            href="/about-us"
            style="font-size:0.9375rem; font-weight:500; color:#5A5D5A; text-decoration:none; padding:0.875rem 0; display:flex; align-items:center; gap:0.4rem; transition:color 0.15s;"
            onmouseover="this.style.color='#18191A'"
            onmouseout="this.style.color='#5A5D5A'"
          >
            About Ferenc →
          </a>
        </div>

      </div>

      <!-- Portrait -->
      <div class="hero-portrait" style="flex-shrink:0; position:relative;">
        <div style="width:300px; height:360px; border-radius:4px; overflow:hidden; position:relative;">
          <Image
            src={ferencPhoto}
            alt="Ferenc Csulak — Energy & Leadership Advisor"
            width={600}
            height={720}
            style="width:100%; height:100%; object-fit:cover; object-position:center top; display:block;"
            loading="eager"
          />
        </div>
        <!-- Credential badge -->
        <div style="position:absolute; bottom:-1.25rem; left:-1.25rem; background:#18191A; color:#FAFAF7; padding:1rem 1.25rem; border-radius:4px; min-width:160px; border:1px solid #2A2B2A;">
          <p style="font-family:'Newsreader',Georgia,serif; font-size:1.75rem; font-weight:600; color:#2A5C34; margin:0; line-height:1;">40+</p>
          <p style="font-size:0.6875rem; text-transform:uppercase; letter-spacing:0.12em; color:#9B9D9B; margin:0.25rem 0 0; font-weight:500;">Years in Energy</p>
        </div>
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════ STATS STRIP -->
  <div style="border-top:1px solid #E4E5E2; border-bottom:1px solid #E4E5E2; background:#F3F4F1;">
    <div style="max-width:1160px; margin:0 auto; padding:2rem 1.5rem; display:grid; grid-template-columns:repeat(4,1fr); gap:0;">
      {[
        ['6', 'C-Suite Roles'],
        ['5', 'Countries'],
        ['3', 'Languages'],
        ['1M+', 'Customers Served'],
      ].map(([num, label], i) => (
        <div style={`padding:0 2rem; ${i > 0 ? 'border-left:1px solid #E4E5E2;' : ''} text-align:center;`}>
          <p style="font-family:'Newsreader',Georgia,serif; font-size:2.25rem; font-weight:600; color:#2A5C34; margin:0; line-height:1; letter-spacing:-0.02em;">{num}</p>
          <p style="font-size:0.75rem; font-weight:500; text-transform:uppercase; letter-spacing:0.12em; color:#9B9D9B; margin:0.4rem 0 0;">{label}</p>
        </div>
      ))}
    </div>
  </div>

  <!-- ═══════════════════════════════════════════════════ WHAT I DO -->
  <section style="padding:6rem 1.5rem; max-width:1160px; margin:0 auto;">

    <div style="max-width:680px; margin-bottom:3.5rem;">
      <p class="eyebrow" style="margin:0 0 1rem;">What I Do</p>
      <h2 style="font-family:'Newsreader',Georgia,serif; font-size:clamp(1.75rem,3.5vw,2.5rem); font-weight:600; color:#18191A; line-height:1.2; margin:0;">
        Practical expertise, delivered with honesty.
      </h2>
    </div>

    <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(300px,1fr)); gap:1.5px; background:#E4E5E2; border:1px solid #E4E5E2; border-radius:4px; overflow:hidden;">
      {focusAreas.map((area) => (
        <a
          href={area.href}
          style="display:block; text-decoration:none; color:inherit; padding:2.25rem; background:#FAFAF7; transition:background-color 0.2s;"
          onmouseover="this.style.backgroundColor='#F3F4F1'"
          onmouseout="this.style.backgroundColor='#FAFAF7'"
        >
          <span style="font-size:0.625rem; font-weight:600; text-transform:uppercase; letter-spacing:0.14em; color:#C8CAC5; display:block; margin-bottom:1.25rem;">{area.n}</span>
          <h3 style="font-family:'Newsreader',Georgia,serif; font-size:1.25rem; font-weight:600; color:#18191A; margin:0 0 0.75rem; line-height:1.3;">{area.title}</h3>
          <p style="font-size:0.9375rem; color:#5A5D5A; line-height:1.7; margin:0 0 1.5rem;">{area.body}</p>
          <span style="font-size:0.8125rem; font-weight:500; color:#2A5C34;">Learn more →</span>
        </a>
      ))}
    </div>

    <div style="margin-top:2rem; text-align:center;">
      <a
        href="/services"
        class="btn-outline"
        style="font-size:0.9375rem;"
      >
        View All Services
      </a>
    </div>

  </section>

  <!-- ═══════════════════════════════════════════════════ ABOUT STRIPE -->
  <section style="border-top:1px solid #E4E5E2; padding:6rem 1.5rem; max-width:1160px; margin:0 auto;">
    <div style="display:grid; grid-template-columns:1fr 1fr; gap:6rem; align-items:center;">

      <div>
        <p class="eyebrow" style="margin:0 0 1rem;">The Advisor</p>
        <h2 style="font-family:'Newsreader',Georgia,serif; font-size:clamp(1.75rem,3vw,2.25rem); font-weight:600; color:#18191A; line-height:1.25; margin:0 0 1.5rem;">
          A career built at the frontier of European energy.
        </h2>
        <p style="font-size:1rem; color:#5A5D5A; line-height:1.8; margin:0 0 1rem;">
          I have served as General Manager and CEO across Delgaz Grid, E.ON Hungária,
          and E.ON Közép-dunántúli — organisations serving millions of households
          across Romania and Hungary.
        </p>
        <p style="font-size:1rem; color:#5A5D5A; line-height:1.8; margin:0 0 2rem;">
          Through A3QENERG, I now channel that experience into advisory work, mentoring,
          and published insights — giving back the knowledge gathered over a career
          spent transforming organisations under pressure.
        </p>
        <a href="/about-us" class="btn-outline" style="font-size:0.9375rem;">
          Full Biography
        </a>
      </div>

      <div style="display:flex; flex-direction:column; gap:1.25rem;">
        {[
          ['General Manager', 'Delgaz Grid', 'Apr 2022 – Present'],
          ['CEO', 'Delgaz Grid', '2017 – 2022'],
          ['CEO', 'E.ON Hungária Zrt.', '2015 – 2017'],
          ['Deputy General Director', 'E.ON Moldova', '2004 – 2008'],
        ].map(([role, company, period], i) => (
          <div style={`display:flex; gap:1.25rem; align-items:flex-start; padding:1.25rem; border:1px solid #E4E5E2; border-radius:3px; ${i === 0 ? 'border-color:#2A5C34; background:#F3F4F1;' : ''}`}>
            <div style={`width:6px; height:6px; border-radius:50%; margin-top:0.4rem; flex-shrink:0; background:${i === 0 ? '#2A5C34' : '#C8CAC5'};`}></div>
            <div>
              <p style="font-size:0.8125rem; font-weight:600; color:#18191A; margin:0 0 0.1rem;">{role}</p>
              <p style="font-size:0.8125rem; color:#5A5D5A; margin:0 0 0.1rem;">{company}</p>
              <p style="font-size:0.75rem; color:#9B9D9B; margin:0;">{period}</p>
            </div>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════ LEAD MAGNET -->
  <LeadMagnet />

  <!-- ═══════════════════════════════════════════════════ LATEST ARTICLES -->
  {recentPosts.length > 0 && (
    <section style="padding:6rem 1.5rem; max-width:1160px; margin:0 auto;">

      <div style="display:flex; justify-content:space-between; align-items:baseline; margin-bottom:3rem; flex-wrap:wrap; gap:1rem;">
        <div>
          <p class="eyebrow" style="margin:0 0 0.75rem;">From the Writing</p>
          <h2 style="font-family:'Newsreader',Georgia,serif; font-size:clamp(1.5rem,3vw,2rem); font-weight:600; color:#18191A; margin:0; line-height:1.25;">
            Latest Articles
          </h2>
        </div>
        <a
          href="/articles"
          style="font-size:0.875rem; font-weight:500; color:#2A5C34; text-decoration:none; transition:color 0.15s;"
          onmouseover="this.style.color='#1A3D22'"
          onmouseout="this.style.color='#2A5C34'"
        >
          All articles →
        </a>
      </div>

      <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(320px,1fr)); gap:1px; background:#E4E5E2; border:1px solid #E4E5E2; border-radius:4px; overflow:hidden;">
        {recentPosts.map((post) => (
          <article>
            <a
              href={`/articles/${post.slug}`}
              style="display:flex; flex-direction:column; text-decoration:none; color:inherit; padding:2rem; background:#FAFAF7; height:100%; transition:background-color 0.15s;"
              onmouseover="this.style.backgroundColor='#F3F4F1'"
              onmouseout="this.style.backgroundColor='#FAFAF7'"
            >
              {getCategories(post)[0] && (
                <p style="font-size:0.625rem; font-weight:600; text-transform:uppercase; letter-spacing:0.14em; color:#2A5C34; margin:0 0 0.875rem;">
                  {getCategories(post)[0]}
                </p>
              )}
              <h3 style="font-family:'Newsreader',Georgia,serif; font-size:1.1875rem; font-weight:600; color:#18191A; line-height:1.3; margin:0 0 0.875rem; flex:1;">
                {post.title.rendered}
              </h3>
              <p style="font-size:0.875rem; color:#5A5D5A; line-height:1.7; margin:0 0 1.5rem;">
                {stripHtml(post.excerpt.rendered).slice(0, 130)}…
              </p>
              <div style="display:flex; align-items:center; gap:0.6rem; font-size:0.75rem; color:#9B9D9B; margin-top:auto;">
                <time datetime={post.date}>{formatDate(post.date)}</time>
              </div>
            </a>
          </article>
        ))}
      </div>

    </section>
  )}

  <!-- ═══════════════════════════════════════════════════ CTA BAND -->
  <section style="background:#18191A; padding:6rem 1.5rem;">
    <div style="max-width:640px; margin:0 auto; text-align:center;">
      <p class="eyebrow" style="color:#2A5C34; margin:0 0 1.25rem;">Ready to Work Together?</p>
      <h2 style="font-family:'Newsreader',Georgia,serif; font-size:clamp(1.75rem,3.5vw,2.5rem); font-weight:600; color:#FAFAF7; line-height:1.2; margin:0 0 1.25rem;">
        Let's talk about your organisation's future.
      </h2>
      <p style="font-size:1rem; color:#9B9D9B; line-height:1.7; margin:0 0 2.5rem;">
        A 30-minute conversation to understand your challenges
        and explore how I can help. No obligation.
      </p>
      <div style="display:flex; flex-wrap:wrap; justify-content:center; gap:0.875rem;">
        <a
          href="/contact"
          style="padding:0.9rem 2.25rem; background:#2A5C34; color:#FAFAF7; font-size:1rem; font-weight:600; text-decoration:none; border-radius:3px; transition:background-color 0.2s; letter-spacing:0.01em;"
          onmouseover="this.style.backgroundColor='#3D7048'"
          onmouseout="this.style.backgroundColor='#2A5C34'"
        >
          Book a Call
        </a>
        <a
          href="/services"
          style="padding:0.9rem 2.25rem; background:transparent; color:#E4E5E2; font-size:1rem; font-weight:500; text-decoration:none; border-radius:3px; border:1px solid #2A2B2A; transition:border-color 0.2s; letter-spacing:0.01em;"
          onmouseover="this.style.borderColor='#5A5D5A'"
          onmouseout="this.style.borderColor='#2A2B2A'"
        >
          View Services
        </a>
      </div>
    </div>
  </section>

</Layout>

<style>
  @media (max-width: 860px) {
    .hero-portrait { display: none !important; }
  }
  @media (max-width: 640px) {
    /* Stats strip: 2 col on mobile */
    div[style*="grid-template-columns:repeat(4,1fr)"] {
      grid-template-columns: repeat(2, 1fr) !important;
    }
    div[style*="grid-template-columns:1fr 1fr"] {
      grid-template-columns: 1fr !important;
      gap: 2.5rem !important;
    }
  }
</style>
